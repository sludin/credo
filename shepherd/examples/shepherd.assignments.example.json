      "sans":        ["vigil.${vigilDomain}"],
      "identityUri": "${identityPrefix}/service/vigil",
      "validation":  { "type": "none-01" }
    },
    {
      "certName":    "corgi-01.${vigilDomain}",
      "corgi":       "corgi-01",
      "ca":          "vigil",
      "domain":      "corgi-01.${vigilDomain}",
      "sans":        ["corgi-01.${vigilDomain}"],
      "identityUri": "${identityPrefix}/node/corgi-01",
      "validation":  { "type": "none-01" }
    }
  ]
