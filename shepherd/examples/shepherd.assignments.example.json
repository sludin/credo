      "domain":      "shepherd.${vigilDomain}",
      "sans":        ["shepherd.${vigilDomain}"],
      "identityUri": "${identityPrefix}/service/shepherd",
      "validation":  { "type": "none-01" }
    },
    {
      "certName":    "vigil.${vigilDomain}",
      "corgi":       "corgi-vigil",
      "ca":          "vigil",
