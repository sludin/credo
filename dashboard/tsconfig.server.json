{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist/server",
    "rootDir": "./server",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "vite": ["node_modules/vite/dist/node/index.d.ts"]
    }
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules", "dist", "server/**/*.test.ts"]
}
