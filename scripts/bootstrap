#!/usr/bin/env bash
set -euo pipefail

if (( BASH_VERSINFO[0] < 4 )); then
  echo "[bootstrap] Requires bash 4+. macOS users: brew install bash" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=scripts/lib/prompts.sh
source "$SCRIPT_DIR/lib/prompts.sh"
# shellcheck source=scripts/lib/config-gen.sh
source "$SCRIPT_DIR/lib/config-gen.sh"

# ---------------------------------------------------------------------------
# Globals — service configuration (remote paths)
# ---------------------------------------------------------------------------

CREDO_ROOT=""
CA_TRUST_PATH=""
DOMAIN=""

VIGIL_HOSTNAME=""
VIGIL_PORT=""
VIGIL_INT_CA_KEY_PATH=""
VIGIL_INT_CA_CERT_PATH=""
VIGIL_DIR=""
VIGIL_IDENTITY_URI=""

SHEPHERD_HOSTNAME=""
SHEPHERD_AGENT_PORT=""
SHEPHERD_DASHBOARD_PORT=""
SHEPHERD_DIR=""
SHEPHERD_IDENTITY_URI=""

CORGI_NAME=""
CORGI_HOSTNAME=""
CORGI_PORT=""
CORGI_BOOTSTRAP_PORT=""
CORGI_HTTP_CHALLENGE_PORT=""
CORGI_DIR=""
CORGI_IDENTITY_URI=""

WANT_DASHBOARD=false
DASHBOARD_HOSTNAME=""
DASHBOARD_PORT="7030"
DASHBOARD_DIR=""
DASHBOARD_IDENTITY_URI=""

ADMIN_USERNAME=""
ADMIN_IDENTITY_URI=""
ADMIN_OUT_CERT=""
ADMIN_OUT_KEY=""
ADMIN_EMAIL=""
ADMIN_DISPLAY_NAME=""

# Ceremony variables (collected in Phase 0, used in Phase 1)
ORG=""
COUNTRY="US"
ROOT_ECDSA_CN=""
INT_ECDSA_CN=""
PKI_BASE_URL="http://pki.example.com"
ROOT_DAYS="3650"
INT_DAYS="730"

DNS_OVERRIDE_JSON=""

# ---------------------------------------------------------------------------
# Globals — connection + control
# ---------------------------------------------------------------------------

INSTALL_CONFIG="$REPO_DIR/.install.json"
BOOTSTRAP_JSON="${BOOTSTRAP_JSON:-$REPO_DIR/bootstrap.json}"
BOOTSTRAP_DEFAULT="$REPO_DIR/bootstrap-default.json"

REMOTE_HOST=""
REMOTE_PORT="22"
REMOTE_SSH_OPTS=""

# Local ceremony CA dir (where ceremony scripts write their output)
LOCAL_CA_DIR="$REPO_DIR/scripts/ceremony/ca"

AUTO=false
DRY_RUN=false
SKIP_CEREMONY=false
PHASE_ONLY=""

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() { printf '[bootstrap] Error: %s\n' "$*" >&2; exit 1; }

phase() { printf '\n[bootstrap] === Phase %s ===\n' "$*"; }

banner() {
  printf '\n[bootstrap] %s\n' "========================================"
  printf '[bootstrap] %s\n' "$1"
  printf '[bootstrap] %s\n' "========================================"
}

remote_run() {
  local cmd="$1"
  if [[ "$REMOTE_HOST" == "local" || "$REMOTE_HOST" == "localhost" || "$REMOTE_HOST" == "127.0.0.1" ]]; then
    bash -c "$cmd"
  else
    # </dev/null prevents sudo from hanging waiting for a password on the SSH stdin pipe
    # shellcheck disable=SC2086
    ssh -p "$REMOTE_PORT" $REMOTE_SSH_OPTS "$REMOTE_HOST" "$cmd" </dev/null
  fi
}

remote_copy() {
  local src="$1" dest_dir="$2" dest_user="${3:-}" dest_group="${4:-}"
  local owner
  dest_group="${dest_group:-$dest_user}"
  owner="${dest_user}${dest_group:+:${dest_group}}"
  if [[ "$REMOTE_HOST" == "local" || "$REMOTE_HOST" == "localhost" || "$REMOTE_HOST" == "127.0.0.1" ]]; then
    if [[ -n "$dest_user" ]]; then
      sudo -u "$dest_user" mkdir -p "$dest_dir"
      sudo cp "$src" "$dest_dir/"
      sudo chown "${owner}" "${dest_dir}/$(basename "$src")"
    else
      mkdir -p "$dest_dir"
      cp "$src" "$dest_dir/"
    fi
  else
    local ssh_e="ssh -p ${REMOTE_PORT}${REMOTE_SSH_OPTS:+ }${REMOTE_SSH_OPTS}"
    local tmp="/tmp/bootstrap-upload-$$-$(basename "$src")"
    # -L dereferences symlinks so absolute symlinks (ceremony CA live/ layout) copy as real files
    # shellcheck disable=SC2086
    rsync -aLz -e "$ssh_e" "$src" "${REMOTE_HOST}:${tmp}"
    if [[ -n "$dest_user" ]]; then
      remote_run "sudo mkdir -p '$dest_dir' && sudo mv '$tmp' '${dest_dir}/$(basename "$src")' && sudo chown '${owner}' '${dest_dir}/$(basename "$src")'"
    else
      remote_run "sudo mkdir -p '$dest_dir' && sudo mv '$tmp' '${dest_dir}/$(basename "$src")'"
    fi
  fi
}

remote_copy_dir() {
  local src_dir="$1" dest_dir="$2" dest_user="${3:-}" dest_group="${4:-}"
  local owner
  dest_group="${dest_group:-$dest_user}"
  owner="${dest_user}${dest_group:+:${dest_group}}"
  if [[ "$REMOTE_HOST" == "local" || "$REMOTE_HOST" == "localhost" || "$REMOTE_HOST" == "127.0.0.1" ]]; then
    if [[ -n "$dest_user" ]]; then
      sudo -u "$dest_user" mkdir -p "$dest_dir"
      sudo cp -r "${src_dir}/." "$dest_dir/"
      sudo chown -R "${owner}" "$dest_dir"
    else
      mkdir -p "$dest_dir"
      cp -r "${src_dir}/." "$dest_dir/"
    fi
  else
    local ssh_e="ssh -p ${REMOTE_PORT}${REMOTE_SSH_OPTS:+ }${REMOTE_SSH_OPTS}"
    local tmp="/tmp/bootstrap-upload-dir-$$"
    remote_run "mkdir -p '$tmp'"
    # -L dereferences symlinks so absolute symlinks copy as real files
    # shellcheck disable=SC2086
    rsync -aLz -e "$ssh_e" "${src_dir}/" "${REMOTE_HOST}:${tmp}/"
    if [[ -n "$dest_user" ]]; then
      remote_run "sudo mkdir -p '$dest_dir' && sudo rsync -a '${tmp}/' '${dest_dir}/' && sudo chown -R '${owner}' '$dest_dir' && rm -rf '$tmp'"
    else
      remote_run "sudo mkdir -p '$dest_dir' && sudo rsync -a '${tmp}/' '${dest_dir}/' && rm -rf '$tmp'"
    fi
  fi
}

# ---------------------------------------------------------------------------
# Defaults file helpers (same format as wizard/bootstrap-wizard)
# ---------------------------------------------------------------------------

ORIG_DEFAULTS=""

_df() {
  local jq_path="$1" fallback="${2:-}"
  local val=""
  if [[ -n "$ORIG_DEFAULTS" ]]; then
    val=$(printf '%s' "$ORIG_DEFAULTS" | jq -r "$jq_path // empty" 2>/dev/null || true)
  fi
  printf '%s' "${val:-$fallback}"
}

_require_df() {
  local field="$1" jq_path="$2" fallback="${3:-}"
  local val
  val=$(_df "$jq_path" "$fallback")
  if [[ -z "$val" ]]; then
    die "--auto mode requires $field to be set in the bootstrap answers file"
  fi
  printf '%s' "$val"
}

save_bootstrap() {
  local dns_arg="${DNS_OVERRIDE_JSON:-null}"
  local skip_ceremony_json
  $SKIP_CEREMONY && skip_ceremony_json="true" || skip_ceremony_json="false"
  jq -n \
    --arg  credoRoot              "$CREDO_ROOT" \
    --arg  caTrustPath            "$CA_TRUST_PATH" \
    --arg  domain                 "$DOMAIN" \
    --arg  org                    "$ORG" \
    --arg  country                "$COUNTRY" \
    --arg  rootEcdsaCn            "$ROOT_ECDSA_CN" \
    --arg  intEcdsaCn             "$INT_ECDSA_CN" \
    --arg  pkiBaseUrl             "$PKI_BASE_URL" \
    --argjson rootDays            "${ROOT_DAYS:-3650}" \
    --argjson intDays             "${INT_DAYS:-730}" \
    --argjson ceremonyAlreadyRan  "$skip_ceremony_json" \
    --arg  vigilHostname          "$VIGIL_HOSTNAME" \
    --argjson vigilPort           "${VIGIL_PORT:-0}" \
    --arg  vigilIntCaKeyPath      "$VIGIL_INT_CA_KEY_PATH" \
    --arg  vigilIntCaCertPath     "$VIGIL_INT_CA_CERT_PATH" \
    --arg  vigilDir               "$VIGIL_DIR" \
    --arg  vigilIdentityUri       "$VIGIL_IDENTITY_URI" \
    --arg  shepherdHostname       "$SHEPHERD_HOSTNAME" \
    --argjson shepherdAgentPort   "${SHEPHERD_AGENT_PORT:-0}" \
    --argjson shepherdDashPort    "${SHEPHERD_DASHBOARD_PORT:-0}" \
    --arg  shepherdDir            "$SHEPHERD_DIR" \
    --arg  shepherdIdentityUri    "$SHEPHERD_IDENTITY_URI" \
    --arg  corgiName              "$CORGI_NAME" \
    --arg  corgiHostname          "$CORGI_HOSTNAME" \
    --argjson corgiPort           "${CORGI_PORT:-0}" \
    --argjson corgiBootstrapPort  "${CORGI_BOOTSTRAP_PORT:-0}" \
    --argjson corgiHttpPort       "${CORGI_HTTP_CHALLENGE_PORT:-0}" \
    --arg  corgiDir               "$CORGI_DIR" \
    --arg  corgiIdentityUri       "$CORGI_IDENTITY_URI" \
    --arg  adminUsername          "$ADMIN_USERNAME" \
    --arg  adminIdentityUri       "$ADMIN_IDENTITY_URI" \
    --arg  adminOutCert           "$ADMIN_OUT_CERT" \
    --arg  adminOutKey            "$ADMIN_OUT_KEY" \
    --arg  adminEmail             "$ADMIN_EMAIL" \
    --arg  adminDisplayName       "$ADMIN_DISPLAY_NAME" \
    --arg  dashboardHostname      "$DASHBOARD_HOSTNAME" \
    --argjson dashboardPort       "${DASHBOARD_PORT:-7030}" \
    --arg  dashboardDir           "$DASHBOARD_DIR" \
    --arg  dashboardIdentityUri   "$DASHBOARD_IDENTITY_URI" \
    --argjson dnsOverride         "$dns_arg" \
    '{
      credoRoot:   $credoRoot,
      caTrustPath: $caTrustPath,
      domain:      $domain,
      ceremony: {
        alreadyRan:  $ceremonyAlreadyRan,
        org:         $org,
        country:     $country,
        rootEcdsaCn: $rootEcdsaCn,
        intEcdsaCn:  $intEcdsaCn,
        pkiBaseUrl:  $pkiBaseUrl,
        rootDays:    $rootDays,
        intDays:     $intDays
      },
      vigil: {
        hostname:      $vigilHostname,
        port:          $vigilPort,
        intCaKeyPath:  $vigilIntCaKeyPath,
        intCaCertPath: $vigilIntCaCertPath,
        dir:           $vigilDir,
        identityUri:   $vigilIdentityUri
      },
      shepherd: {
        hostname:      $shepherdHostname,
        agentPort:     $shepherdAgentPort,
        dashboardPort: $shepherdDashPort,
        dir:           $shepherdDir,
        identityUri:   $shepherdIdentityUri
      },
      corgi: {
        name:              $corgiName,
        hostname:          $corgiHostname,
        port:              $corgiPort,
        bootstrapPort:     $corgiBootstrapPort,
        httpChallengePort: $corgiHttpPort,
        dir:               $corgiDir,
        identityUri:       $corgiIdentityUri
      },
      admin: {
        username:    $adminUsername,
        identityUri: $adminIdentityUri,
        outCert:     $adminOutCert,
        outKey:      $adminOutKey,
        email:       $adminEmail,
        displayName: $adminDisplayName
      },
      dashboard: {
        hostname:    $dashboardHostname,
        port:        $dashboardPort,
        dir:         $dashboardDir,
        identityUri: $dashboardIdentityUri
      }
    }
    | if $dnsOverride != null then . + {dnsOverride: $dnsOverride} else . end' \
    > "$BOOTSTRAP_JSON"
}

# ---------------------------------------------------------------------------
# Phase 0 — Collect answers
# ---------------------------------------------------------------------------

load_install_config() {
  if [[ ! -f "$INSTALL_CONFIG" ]]; then
    # Running on the target host itself — no SSH needed.
    REMOTE_HOST="local"
    return 0
  fi
  local jq_err
  jq_err="$(jq -r '(.shepherd // .vigil // .corgis[0]) | .host // empty' "$INSTALL_CONFIG" 2>&1)" && REMOTE_HOST="$jq_err" || {
    echo "[bootstrap] jq error reading host from $INSTALL_CONFIG: $jq_err" >&2
    REMOTE_HOST=""
  }
  REMOTE_PORT="$(jq -r '(.shepherd // .vigil // .corgis[0]) | .sshPort // 22' "$INSTALL_CONFIG" 2>/dev/null || true)"
  REMOTE_SSH_OPTS="$(jq -r '(.shepherd // .vigil // .corgis[0]) | .sshOpts // ""' "$INSTALL_CONFIG" 2>/dev/null || true)"
  if [[ -z "$REMOTE_HOST" ]]; then
    echo "[bootstrap] Note: could not determine host from $INSTALL_CONFIG, defaulting to local" >&2
    REMOTE_HOST="local"
  fi
  if jq -e '.dashboard // empty' "$INSTALL_CONFIG" >/dev/null 2>&1; then
    WANT_DASHBOARD=true
  fi
}

load_defaults() {
  local defaults_path=""
  if [[ -f "$BOOTSTRAP_JSON" ]]; then
    defaults_path="$BOOTSTRAP_JSON"
  elif [[ -f "$BOOTSTRAP_DEFAULT" ]]; then
    defaults_path="$BOOTSTRAP_DEFAULT"
  fi
  if [[ -n "$defaults_path" ]]; then
    ORIG_DEFAULTS=$(cat "$defaults_path")
  fi
}

collect_answers() {
  load_defaults

  DNS_OVERRIDE_JSON=$(_df '.dnsOverride' '')
  if [[ "$DNS_OVERRIDE_JSON" == "null" ]]; then DNS_OVERRIDE_JSON=""; fi

  printf '\n=== Base ===\n'
  local _def_root
  if [[ -f "$INSTALL_CONFIG" ]]; then
    _def_root="$(jq -r '(.shepherd // .vigil // .corgis[0]) | .remoteDir // empty' "$INSTALL_CONFIG" | sed 's|/[^/]*$||')"
  fi
  [[ -z "${_def_root:-}" ]] && _def_root="$REPO_DIR"

  if $AUTO; then
    CREDO_ROOT=$(_require_df 'credoRoot' '.credoRoot' "$_def_root")
    DOMAIN=$(_require_df 'domain' '.domain')
    CA_TRUST_PATH=$(_require_df 'caTrustPath' '.caTrustPath' "$CREDO_ROOT/ca/root-ecdsa.cert.pem")
  else
    ask_required 'Remote base directory (credoRoot)' "$(_df '.credoRoot' "$_def_root")"
    CREDO_ROOT="$REPLY_VAL"
    ask_required 'Base domain (e.g. example.com)' "$(_df '.domain')"
    DOMAIN="$REPLY_VAL"
    ask_required 'CA trust bundle path (remote)' "$(_df '.caTrustPath' "$CREDO_ROOT/ca/root-ecdsa.cert.pem")"
    CA_TRUST_PATH="$REPLY_VAL"
  fi
  save_bootstrap

  printf '\n=== Ceremony ===\n'
  local _def_ca_ran="n"
  if [[ -f "$LOCAL_CA_DIR/int-ecdsa/certs/int-ecdsa.chain.pem" ]]; then
    _def_ca_ran="y"
  fi
  if $AUTO; then
    local _auto_ran
    _auto_ran=$(_df '.ceremony.alreadyRan' 'false')
    [[ "$_auto_ran" == "true" ]] && SKIP_CEREMONY=true || SKIP_CEREMONY=false
  else
    ask 'Has the PKI ceremony already run? (y/n)' "$_def_ca_ran"
    [[ "${REPLY_VAL,,}" == y* ]] && SKIP_CEREMONY=true || SKIP_CEREMONY=false
  fi
  if ! $SKIP_CEREMONY; then
    if $AUTO; then
      ORG=$(_require_df 'ceremony.org' '.ceremony.org')
      COUNTRY=$(_require_df 'ceremony.country' '.ceremony.country' 'US')
      ROOT_ECDSA_CN=$(_require_df 'ceremony.rootEcdsaCn' '.ceremony.rootEcdsaCn' "$ORG Root")
      INT_ECDSA_CN=$(_require_df 'ceremony.intEcdsaCn' '.ceremony.intEcdsaCn' "$ORG Intermediary")
      PKI_BASE_URL=$(_require_df 'ceremony.pkiBaseUrl' '.ceremony.pkiBaseUrl' "http://pki.$DOMAIN")
      ROOT_DAYS=$(_require_df 'ceremony.rootDays' '.ceremony.rootDays' '3650')
      INT_DAYS=$(_require_df 'ceremony.intDays' '.ceremony.intDays' '730')
    else
      ask_required 'Organization name (for CA DN)' "$(_df '.ceremony.org')"
      ORG="$REPLY_VAL"
      ask 'Country code' "$(_df '.ceremony.country' 'US')"
      COUNTRY="${REPLY_VAL:-US}"
      ask_required 'Root CA common name' "$(_df '.ceremony.rootEcdsaCn' "$ORG Root")"
      ROOT_ECDSA_CN="$REPLY_VAL"
      ask_required 'Intermediate CA common name' "$(_df '.ceremony.intEcdsaCn' "$ORG Intermediary")"
      INT_ECDSA_CN="$REPLY_VAL"
      ask 'PKI base URL (for AIA/CDP extensions)' "$(_df '.ceremony.pkiBaseUrl' "http://pki.$DOMAIN")"
      PKI_BASE_URL="${REPLY_VAL:-http://pki.$DOMAIN}"
      ask 'Root cert validity days' "$(_df '.ceremony.rootDays' '3650')"
      ROOT_DAYS="${REPLY_VAL:-3650}"
      ask 'Intermediate cert validity days' "$(_df '.ceremony.intDays' '730')"
      INT_DAYS="${REPLY_VAL:-730}"
    fi
  fi
  save_bootstrap

  printf '\n=== Vigil ===\n'
  local _def_vigil_key="$CREDO_ROOT/ca/int-ecdsa/private/int-ecdsa.key.pem"
  local _def_vigil_cert="$CREDO_ROOT/ca/int-ecdsa/certs/int-ecdsa.cert.pem"
  local _def_vigil_dir
  _def_vigil_dir="$(jq -r '.vigil.remoteDir // empty' "$INSTALL_CONFIG" || true)"
  [[ -z "$_def_vigil_dir" ]] && _def_vigil_dir="$CREDO_ROOT/vigil"

  if $AUTO; then
    VIGIL_HOSTNAME=$(_require_df 'vigil.hostname' '.vigil.hostname' "vigil.$DOMAIN")
    VIGIL_PORT=$(_require_df 'vigil.port' '.vigil.port' '7020')
    VIGIL_INT_CA_KEY_PATH=$(_require_df 'vigil.intCaKeyPath' '.vigil.intCaKeyPath' "$_def_vigil_key")
    VIGIL_INT_CA_CERT_PATH=$(_require_df 'vigil.intCaCertPath' '.vigil.intCaCertPath' "$_def_vigil_cert")
    VIGIL_DIR=$(_require_df 'vigil.dir' '.vigil.dir' "$_def_vigil_dir")
    VIGIL_IDENTITY_URI=$(_require_df 'vigil.identityUri' '.vigil.identityUri' 'vigil://credo/service/vigil')
  else
    ask_required 'Vigil hostname' "$(_df '.vigil.hostname' "vigil.$DOMAIN")"
    VIGIL_HOSTNAME="$REPLY_VAL"
    ask_int 'Vigil port' "$(_df '.vigil.port' '7020')"
    VIGIL_PORT="$REPLY_VAL"
    ask_required 'Intermediate CA private key path (remote)' "$(_df '.vigil.intCaKeyPath' "$_def_vigil_key")"
    VIGIL_INT_CA_KEY_PATH="$REPLY_VAL"
    ask_required 'Intermediate CA cert path (remote)' "$(_df '.vigil.intCaCertPath' "$_def_vigil_cert")"
    VIGIL_INT_CA_CERT_PATH="$REPLY_VAL"
    ask_required 'Vigil remote directory' "$(_df '.vigil.dir' "$_def_vigil_dir")"
    VIGIL_DIR="$REPLY_VAL"
    ask_required 'Vigil identity URI' "$(_df '.vigil.identityUri' 'vigil://credo/service/vigil')"
    VIGIL_IDENTITY_URI="$REPLY_VAL"
  fi
  save_bootstrap

  printf '\n=== Shepherd ===\n'
  local _def_shepherd_dir
  _def_shepherd_dir="$(jq -r '.shepherd.remoteDir // empty' "$INSTALL_CONFIG" || true)"
  [[ -z "$_def_shepherd_dir" ]] && _def_shepherd_dir="$CREDO_ROOT/shepherd"

  if $AUTO; then
    SHEPHERD_HOSTNAME=$(_require_df 'shepherd.hostname' '.shepherd.hostname' "shepherd.$DOMAIN")
    SHEPHERD_AGENT_PORT=$(_require_df 'shepherd.agentPort' '.shepherd.agentPort' '7010')
    SHEPHERD_DASHBOARD_PORT=$(_require_df 'shepherd.dashboardPort' '.shepherd.dashboardPort' '7011')
    SHEPHERD_DIR=$(_require_df 'shepherd.dir' '.shepherd.dir' "$_def_shepherd_dir")
    SHEPHERD_IDENTITY_URI=$(_require_df 'shepherd.identityUri' '.shepherd.identityUri' 'vigil://credo/service/shepherd')
  else
    ask_required 'Shepherd hostname' "$(_df '.shepherd.hostname' "shepherd.$DOMAIN")"
    SHEPHERD_HOSTNAME="$REPLY_VAL"
    ask_int 'Shepherd agent port' "$(_df '.shepherd.agentPort' '7010')"
    SHEPHERD_AGENT_PORT="$REPLY_VAL"
    ask_int 'Shepherd dashboard port' "$(_df '.shepherd.dashboardPort' '7011')"
    SHEPHERD_DASHBOARD_PORT="$REPLY_VAL"
    ask_required 'Shepherd remote directory' "$(_df '.shepherd.dir' "$_def_shepherd_dir")"
    SHEPHERD_DIR="$REPLY_VAL"
    ask_required 'Shepherd identity URI' "$(_df '.shepherd.identityUri' 'vigil://credo/service/shepherd')"
    SHEPHERD_IDENTITY_URI="$REPLY_VAL"
  fi
  save_bootstrap

  printf '\n=== Corgi ===\n'
  local _def_corgi_dir
  _def_corgi_dir="$(jq -r '.corgis[0].remoteDir // empty' "$INSTALL_CONFIG" || true)"
  [[ -z "$_def_corgi_dir" ]] && _def_corgi_dir="$CREDO_ROOT/corgi"
  local _def_corgi_name
  _def_corgi_name="$(jq -r '.corgis[0].name // empty' "$INSTALL_CONFIG" || true)"
  [[ -z "$_def_corgi_name" ]] && _def_corgi_name="corgi-01"

  if $AUTO; then
    CORGI_NAME=$(_require_df 'corgi.name' '.corgi.name' "$_def_corgi_name")
    CORGI_HOSTNAME=$(_require_df 'corgi.hostname' '.corgi.hostname' "${CORGI_NAME}.$DOMAIN")
    CORGI_PORT=$(_require_df 'corgi.port' '.corgi.port' '7001')
    CORGI_BOOTSTRAP_PORT=$(_require_df 'corgi.bootstrapPort' '.corgi.bootstrapPort' "$(( CORGI_PORT + 1 ))")
    CORGI_HTTP_CHALLENGE_PORT=$(_require_df 'corgi.httpChallengePort' '.corgi.httpChallengePort' '7080')
    CORGI_DIR=$(_require_df 'corgi.dir' '.corgi.dir' "$_def_corgi_dir")
    CORGI_IDENTITY_URI=$(_require_df 'corgi.identityUri' '.corgi.identityUri' "vigil://credo/service/corgi/$CORGI_NAME")
  else
    ask_required 'Corgi node name' "$(_df '.corgi.name' "$_def_corgi_name")"
    CORGI_NAME="$REPLY_VAL"
    ask_required 'Corgi hostname' "$(_df '.corgi.hostname' "${CORGI_NAME}.$DOMAIN")"
    CORGI_HOSTNAME="$REPLY_VAL"
    ask_int 'Corgi mTLS port' "$(_df '.corgi.port' '7001')"
    CORGI_PORT="$REPLY_VAL"
    ask_int 'Corgi bootstrap port' "$(_df '.corgi.bootstrapPort' "$(( CORGI_PORT + 1 ))")"
    CORGI_BOOTSTRAP_PORT="$REPLY_VAL"
    ask_int 'Corgi HTTP challenge port' "$(_df '.corgi.httpChallengePort' '7080')"
    CORGI_HTTP_CHALLENGE_PORT="$REPLY_VAL"
    ask_required 'Corgi remote directory' "$(_df '.corgi.dir' "$_def_corgi_dir")"
    CORGI_DIR="$REPLY_VAL"
    ask_required 'Corgi identity URI' "$(_df '.corgi.identityUri' "vigil://credo/service/corgi/$CORGI_NAME")"
    CORGI_IDENTITY_URI="$REPLY_VAL"
  fi
  save_bootstrap

  if $WANT_DASHBOARD; then
    collect_dashboard_answers
  fi
}

collect_admin_answers() {
  printf '\n=== Admin account ===\n'
  local _def_username="admin"

  if $AUTO; then
    ADMIN_USERNAME=$(_require_df 'admin.username' '.admin.username' "$_def_username")
    ADMIN_OUT_CERT=$(expand_home "$(_require_df 'admin.outCert' '.admin.outCert' "$HOME/.credo/$DOMAIN/${ADMIN_USERNAME}.pem")")
    ADMIN_OUT_KEY=$(expand_home "$(_require_df 'admin.outKey'   '.admin.outKey'  "$HOME/.credo/$DOMAIN/${ADMIN_USERNAME}.key")")
    ADMIN_EMAIL=$(       _require_df 'admin.email'       '.admin.email'       "${ADMIN_USERNAME}@${DOMAIN}")
    ADMIN_DISPLAY_NAME=$(_require_df 'admin.displayName' '.admin.displayName' "$ADMIN_USERNAME")
  else
    ask_required 'Admin username' "$(_df '.admin.username' "$_def_username")"
    ADMIN_USERNAME="$REPLY_VAL"
    ask_required 'Admin cert output path (local)' "$(_df '.admin.outCert' "$HOME/.credo/$DOMAIN/${ADMIN_USERNAME}.pem")"
    ADMIN_OUT_CERT=$(expand_home "$REPLY_VAL")
    ask_required 'Admin key output path (local)'  "$(_df '.admin.outKey'  "$HOME/.credo/$DOMAIN/${ADMIN_USERNAME}.key")"
    ADMIN_OUT_KEY=$(expand_home "$REPLY_VAL")
    ask_required 'Admin email address' "$(_df '.admin.email'       "${ADMIN_USERNAME}@${DOMAIN}")"
    ADMIN_EMAIL="$REPLY_VAL"
    ask_required 'Admin display name'  "$(_df '.admin.displayName' "$ADMIN_USERNAME")"
    ADMIN_DISPLAY_NAME="$REPLY_VAL"
  fi
  ADMIN_IDENTITY_URI="vigil://credo/user/$ADMIN_USERNAME"
  save_bootstrap
}

collect_dashboard_answers() {
  printf '\n=== Dashboard ===\n'
  local _def_dashboard_dir
  _def_dashboard_dir="$(jq -r '.dashboard.remoteDir // empty' "$INSTALL_CONFIG" 2>/dev/null || true)"
  [[ -z "$_def_dashboard_dir" ]] && _def_dashboard_dir="$CREDO_ROOT/dashboard"

  if $AUTO; then
    DASHBOARD_HOSTNAME=$(     _require_df 'dashboard.hostname'    '.dashboard.hostname'    "dashboard.$DOMAIN")
    DASHBOARD_PORT=$(         _require_df 'dashboard.port'        '.dashboard.port'        '7030')
    DASHBOARD_DIR=$(          _require_df 'dashboard.dir'         '.dashboard.dir'         "$_def_dashboard_dir")
    DASHBOARD_IDENTITY_URI=$( _require_df 'dashboard.identityUri' '.dashboard.identityUri' 'vigil://credo/service/dashboard')
  else
    ask_required 'Dashboard hostname'         "$(_df '.dashboard.hostname'    "dashboard.$DOMAIN")"
    DASHBOARD_HOSTNAME="$REPLY_VAL"
    ask_int      'Dashboard port'             "$(_df '.dashboard.port'        '7030')"
    DASHBOARD_PORT="$REPLY_VAL"
    ask_required 'Dashboard remote directory' "$(_df '.dashboard.dir'         "$_def_dashboard_dir")"
    DASHBOARD_DIR="$REPLY_VAL"
    ask_required 'Dashboard identity URI'     "$(_df '.dashboard.identityUri' 'vigil://credo/service/dashboard')"
    DASHBOARD_IDENTITY_URI="$REPLY_VAL"
  fi
  save_bootstrap
}

# ---------------------------------------------------------------------------
# Phase 1 — Ceremony (runs locally)
# ---------------------------------------------------------------------------

phase_ceremony() {
  phase "1 - Ceremony"

  local ceremony_dir="$SCRIPT_DIR/ceremony"
  local ca_dir="$LOCAL_CA_DIR"

  if $SKIP_CEREMONY; then
    echo "[bootstrap] Skipping ceremony (--skip-ceremony)."
    echo "[bootstrap] Ensure CA files are present at: $ca_dir"
    return
  fi

  local root_cert="$ca_dir/root-ecdsa/certs/root-ecdsa.cert.pem"
  local int_chain="$ca_dir/int-ecdsa/certs/int-ecdsa.chain.pem"
  local int_cert="$ca_dir/int-ecdsa/certs/int-ecdsa.cert.pem"
  local int_key="$ca_dir/int-ecdsa/private/int-ecdsa.key.pem"

  if [[ -f "$int_chain" && -f "$int_cert" && -f "$int_key" ]]; then
    echo "[bootstrap] Ceremony already complete. Using existing CA at $ca_dir"
    return
  fi

  echo "[bootstrap] Starting PKI ceremony..."
  echo "[bootstrap] Output will be written to: $ca_dir"

  if $AUTO && [[ -z "${CREDO_ROOT_CA_PASSPHRASE:-}" ]]; then
    echo "[bootstrap] --auto mode with no passphrase: using --no-passphrase for root CA"
  fi

  # Generate openssl.cnf files
  local cnf_opts=(
    --ca-dir "$ca_dir"
    --org "$ORG"
    --country "$COUNTRY"
    --root-ecdsa-cn "$ROOT_ECDSA_CN"
    --int-ecdsa-cn "$INT_ECDSA_CN"
    --pki-base-url "$PKI_BASE_URL"
    --root-days "$ROOT_DAYS"
    --int-days "$INT_DAYS"
    --force
  )
  if $DRY_RUN; then cnf_opts+=(--dry-run); fi
  "$ceremony_dir/generate-openssl-cnf.sh" "${cnf_opts[@]}"

  # Bootstrap root CA
  local root_opts=(--ca-dir "$ca_dir" --force)
  if $DRY_RUN; then root_opts+=(--dry-run); fi
  if $AUTO; then
    root_opts+=(--non-interactive)
    if [[ -z "${CREDO_ROOT_CA_PASSPHRASE:-}" ]]; then
      root_opts+=(--no-passphrase)
    fi
  fi
  "$ceremony_dir/bootstrap-roots.sh" "${root_opts[@]}"

  # Issue intermediate
  local int_opts=(--root-dir "$ca_dir/root-ecdsa" --int-dir "$ca_dir/int-ecdsa" --force)
  if $DRY_RUN; then int_opts+=(--dry-run); fi
  if $AUTO; then int_opts+=(--non-interactive); fi
  "$ceremony_dir/issue-intermediary.sh" "${int_opts[@]}"

  echo "[bootstrap] Ceremony complete."
}

# ---------------------------------------------------------------------------
# Phase 2 — Config generation + file push
# ---------------------------------------------------------------------------

phase_config() {
  phase "2 - Config generation and file push"

  local ca_dir="$LOCAL_CA_DIR"
  local root_cert="$ca_dir/root-ecdsa/certs/root-ecdsa.cert.pem"
  local int_cert="$ca_dir/int-ecdsa/certs/int-ecdsa.cert.pem"
  local int_key="$ca_dir/int-ecdsa/private/int-ecdsa.key.pem"
  local int_chain="$ca_dir/int-ecdsa/certs/int-ecdsa.chain.pem"

  for f in "$root_cert" "$int_cert" "$int_key" "$int_chain"; do
    [[ -f "$f" ]] || die "Missing CA file: $f (run ceremony first)"
  done

  # Generate all service config files to a local temp dir
  local tmp_config_dir
  tmp_config_dir=$(mktemp -d "/tmp/credo-bootstrap-config-XXXXXX")
  trap '[[ -n "${tmp_config_dir:-}" ]] && rm -rf "$tmp_config_dir"' EXIT

  # Set derived directories for config-gen.sh
  # These are REMOTE paths; config-gen.sh uses them to produce JSON
  local vigil_dir_local="$tmp_config_dir/vigil"
  local shepherd_dir_local="$tmp_config_dir/shepherd"
  local corgi_dir_local="$tmp_config_dir/corgi"

  mkdir -p "$vigil_dir_local" "$shepherd_dir_local" "$corgi_dir_local" "$tmp_config_dir/ca"

  # Temporarily override DIR vars for config-gen.sh output paths
  local saved_vigil_dir="$VIGIL_DIR"
  local saved_shepherd_dir="$SHEPHERD_DIR"
  local saved_corgi_dir="$CORGI_DIR"
  local saved_credo_root="$CREDO_ROOT"

  export VIGIL_DIR="$vigil_dir_local"
  export SHEPHERD_DIR="$shepherd_dir_local"
  export CORGI_DIR="$corgi_dir_local"
  export CREDO_ROOT="$tmp_config_dir"

  generate_all_configs "$($DRY_RUN && echo yes || echo no)"

  # Restore
  VIGIL_DIR="$saved_vigil_dir"
  SHEPHERD_DIR="$saved_shepherd_dir"
  CORGI_DIR="$saved_corgi_dir"
  CREDO_ROOT="$saved_credo_root"

  # config-gen uses VIGIL_DIR/SHEPHERD_DIR/CORGI_DIR/CREDO_ROOT for both the output paths
  # AND the content embedded in each config (cert paths, includes, etc.).  Since we set
  # all four to temp dirs, every generated JSON has temp paths baked in.  Replace them all
  # with the real remote paths before pushing.
  while IFS= read -r -d '' cfg; do
    local patched="$cfg.patched"
    sed \
      -e "s|${vigil_dir_local}|${VIGIL_DIR}|g" \
      -e "s|${shepherd_dir_local}|${SHEPHERD_DIR}|g" \
      -e "s|${corgi_dir_local}|${CORGI_DIR}|g" \
      -e "s|${tmp_config_dir}|${CREDO_ROOT}|g" \
      "$cfg" > "$patched" && mv "$patched" "$cfg"
  done < <(find "$tmp_config_dir" -name "*.json" -print0)

  if $DRY_RUN; then
    echo "[bootstrap] Dry run - skipping file push."
    return
  fi

  echo ""
  echo "[bootstrap] Pushing CA files to remote..."

  local ca_remote_dir="$CREDO_ROOT/ca"

  echo "[bootstrap]   mkdir CA dirs..."
  remote_run "sudo mkdir -p '$ca_remote_dir/root-ecdsa/certs' '$ca_remote_dir/int-ecdsa/certs' '$ca_remote_dir/int-ecdsa/private'"

  echo "[bootstrap]   copy root cert..."
  remote_copy "$root_cert"  "$ca_remote_dir/root-ecdsa/certs"
  echo "[bootstrap]   copy int cert..."
  remote_copy "$int_cert"   "$ca_remote_dir/int-ecdsa/certs"
  echo "[bootstrap]   copy int chain..."
  remote_copy "$int_chain"  "$ca_remote_dir/int-ecdsa/certs"
  echo "[bootstrap]   copy int key..."
  remote_copy "$int_key"    "$ca_remote_dir/int-ecdsa/private"

  echo "[bootstrap]   chown int key..."
  remote_run "sudo chown vigil:vigil '$ca_remote_dir/int-ecdsa/private/int-ecdsa.key.pem' && sudo chmod 600 '$ca_remote_dir/int-ecdsa/private/int-ecdsa.key.pem'"
  remote_run "sudo cp '$ca_remote_dir/root-ecdsa/certs/root-ecdsa.cert.pem' '$CREDO_ROOT/ca/root-ecdsa.cert.pem' 2>/dev/null || true"
  # corgi's POST /bootstrap/ca writes the Shepherd CA cert to this path; it must be corgi-writable.
  remote_run "sudo chown corgi:corgi '$CA_TRUST_PATH' && sudo chmod 644 '$CA_TRUST_PATH'"

  echo "[bootstrap] Pushing service config files..."
  echo "[bootstrap]   vigil config..."
  remote_copy_dir "$vigil_dir_local"    "$VIGIL_DIR"    "vigil"
  echo "[bootstrap]   shepherd config..."
  remote_copy_dir "$shepherd_dir_local" "$SHEPHERD_DIR" "shepherd"
  echo "[bootstrap]   corgi config..."
  remote_copy_dir "$corgi_dir_local"    "$CORGI_DIR"    "corgi"

  if [[ -f "$tmp_config_dir/vars.json" ]]; then
    echo "[bootstrap]   vars.json..."
    remote_copy "$tmp_config_dir/vars.json" "$CREDO_ROOT"
  fi

  # Generate and push dashboard config (after real paths are restored — no sed patching needed)
  if $WANT_DASHBOARD; then
    local dashboard_dir_local="$tmp_config_dir/dashboard"
    mkdir -p "$dashboard_dir_local"
    _gen_dashboard_config > "$dashboard_dir_local/dashboard.config.json"
    chmod 600 "$dashboard_dir_local/dashboard.config.json"
    echo "[bootstrap]   dashboard config..."
    remote_copy_dir "$dashboard_dir_local" "$DASHBOARD_DIR" "dashboard"
  fi

  echo "[bootstrap] Files pushed."
}

# ---------------------------------------------------------------------------
# Phase 3 — Remote bootstrap sequence
# ---------------------------------------------------------------------------

phase_bootstrap() {
  phase "3 - Remote bootstrap sequence"

  if $DRY_RUN; then
    echo "[bootstrap] Dry run - skipping remote bootstrap."
    return
  fi

  collect_admin_answers

  local vigil_exec="$VIGIL_DIR/vigil"
  local shepherd_exec="$SHEPHERD_DIR/shepherd"
  local corgi_exec="$CORGI_DIR/corgi"

  # Write the bootstrap script locally, then upload via rsync (avoids </dev/null stdin issue)
  local local_script
  local_script=$(mktemp "/tmp/credo-bootstrap-local-$$.XXXXXX.sh")
  local remote_script="/tmp/credo-bootstrap-remote-$$.sh"

  # shellcheck disable=SC2087
  cat > "$local_script" << REMOTE_SCRIPT_EOF
#!/usr/bin/env bash
set -euo pipefail

VIGIL_EXEC="$vigil_exec"
SHEPHERD_EXEC="$shepherd_exec"
CORGI_EXEC="$corgi_exec"
VIGIL_DIR="$VIGIL_DIR"
SHEPHERD_DIR="$SHEPHERD_DIR"
CORGI_DIR="$CORGI_DIR"
VIGIL_CONFIG_PATH="$VIGIL_DIR/vigil.config.json"
SHEPHERD_CONFIG_PATH="$SHEPHERD_DIR/shepherd.config.json"
CORGI_CONFIG_PATH="$CORGI_DIR/corgi.config.json"
# Bootstrap logs go to /tmp so the SSH user (not the service user) can open them for writing.
# The redirect ">>" is opened by the invoking shell, not by the sudo-u process.
VIGIL_LOG="/tmp/credo-vigil-bootstrap-$$.log"
SHEPHERD_LOG="/tmp/credo-shepherd-bootstrap-$$.log"
CORGI_BOOT_LOG="/tmp/credo-corgi-boot-$$.log"
CORGI_LOG="/tmp/credo-corgi-svc-$$.log"
CORGI_NAME="$CORGI_NAME"
CORGI_HOSTNAME="$CORGI_HOSTNAME"
CORGI_PORT="$CORGI_PORT"
CORGI_BOOTSTRAP_PORT="$CORGI_BOOTSTRAP_PORT"
CORGI_IDENTITY_URI="$CORGI_IDENTITY_URI"
VIGIL_HOSTNAME="$VIGIL_HOSTNAME"
SHEPHERD_HOSTNAME="$SHEPHERD_HOSTNAME"
DOMAIN="$DOMAIN"
ADMIN_IDENTITY_URI="$ADMIN_IDENTITY_URI"
DASHBOARD_HOSTNAME="$DASHBOARD_HOSTNAME"
DASHBOARD_DIR="$DASHBOARD_DIR"
SHEPHERD_ACCOUNTS="\$SHEPHERD_DIR/shepherd.accounts.json"
DASHBOARD_ACCOUNT_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
DASHBOARD_IDENTITY_URI="$DASHBOARD_IDENTITY_URI"
ADMIN_USERNAME="$ADMIN_USERNAME"
ADMIN_EMAIL="$ADMIN_EMAIL"
ADMIN_DISPLAY_NAME="$ADMIN_DISPLAY_NAME"
WANT_DASHBOARD="$WANT_DASHBOARD"
ADMIN_OUT_CERT="$ADMIN_OUT_CERT"
ADMIN_OUT_KEY="$ADMIN_OUT_KEY"

TRACKED_PIDS=()
trap 'for p in "\${TRACKED_PIDS[@]:-}"; do kill "\$p" 2>/dev/null || true; done' EXIT INT TERM
trap '
  echo "[REMOTE ERR] command failed at line \$LINENO: \$BASH_COMMAND" >&2
  echo "[REMOTE ERR] --- vigil log (last 20 lines) ---" >&2
  tail -20 "\$VIGIL_LOG" 2>/dev/null | sed "s/^/  [V] /" >&2
  echo "[REMOTE ERR] --- shepherd log (last 20 lines) ---" >&2
  tail -20 "\$SHEPHERD_LOG" 2>/dev/null | sed "s/^/  [S] /" >&2
  echo "[REMOTE ERR] --- corgi boot log (full) ---" >&2
  cat "\$CORGI_BOOT_LOG" 2>/dev/null | sed "s/^/  [CB] /" >&2
  echo "[REMOTE ERR] --- corgi server log (full) ---" >&2
  cat "\$CORGI_LOG" 2>/dev/null | sed "s/^/  [CS] /" >&2
  echo "[REMOTE ERR] --- shepherd log (full) ---" >&2
  cat "\$SHEPHERD_LOG" 2>/dev/null | sed "s/^/  [S] /" >&2
  echo "[REMOTE ERR] --- corgi store contents ---" >&2
  find "\$CORGI_DIR/store" -type f 2>/dev/null | sed "s/^/  [C] /" >&2
  ls -la "\$CORGI_DIR/store/live" 2>&1 | sed "s/^/  [C] /" >&2
  echo "[REMOTE ERR] --- running processes ---" >&2
  ps aux 2>/dev/null | grep -E "vigil|shepherd|corgi" | grep -v grep | sed "s/^/  [P] /" >&2
' ERR

capture_from_log() {
  local log_file="\$1" timeout_sec="\${2:-90}"
  shift 2
  local -a _vars=() _pats=() _done=()
  local _total=0
  while (( \$# >= 2 )); do
    _vars+=("\$1"); _pats+=("\$2"); _done+=("no"); _total=\$(( _total + 1 )); shift 2
  done
  local _start _found=0 _printed=0
  _start=\$(date +%s)
  while (( _found < _total )); do
    if (( \$(date +%s) - _start >= timeout_sec )); then
      echo "ERROR: timed out after \${timeout_sec}s waiting in \$log_file" >&2; exit 1
    fi
    local _lineno=0 _line
    while IFS= read -r _line; do
      _lineno=\$(( _lineno + 1 ))
      if (( _lineno > _printed )); then echo "  \$_line"; fi
      local _i
      for (( _i=0; _i<_total; _i++ )); do
        if [[ "\${_done[\$_i]}" == "no" ]] && [[ "\$_line" =~ \${_pats[\$_i]} ]]; then
          _done[\$_i]="yes"; _found=\$(( _found+1 ))
          printf -v "\${_vars[\$_i]}" '%s' "\${BASH_REMATCH[1]:-1}"
        fi
      done
    done < "\$log_file"
    _printed=\$_lineno
    if (( _found < _total )); then sleep 0.5; fi
  done
}

wait_for_certs() {
  local issued_after="\$1"; shift
  local timeout_sec=300
  declare -A _pending=()
  for _arg in "\$@"; do _pending["\${_arg#*:}"]="\${_arg%%:*}"; done
  local _deadline=\$(( \$(date +%s) + timeout_sec ))
  local _last_diag=0
  while (( \${#_pending[@]} > 0 )); do
    if (( \$(date +%s) > _deadline )); then
      echo "ERROR: timed out waiting for certs" >&2
      echo "--- shepherd log (last 40 lines) ---" >&2
      tail -40 "\$SHEPHERD_LOG" 2>/dev/null | sed "s/^/  [S] /" >&2
      echo "--- corgi server log (full) ---" >&2
      cat "\$CORGI_LOG" 2>/dev/null | sed "s/^/  [CS] /" >&2
      echo "--- cert store contents ---" >&2
      find "\$CORGI_DIR/store" -type f 2>/dev/null | sed "s/^/  [C] /" >&2
      echo "--- running credo processes ---" >&2
      ps aux 2>/dev/null | grep -E "vigil|shepherd|corgi" | grep -v grep | sed "s/^/  [P] /" >&2
      false  # trigger ERR trap for extra context
    fi
    # Periodic heartbeat every 30s so output shows progress
    local _now=\$(date +%s)
    if (( _now - _last_diag >= 30 )); then
      echo "  [wait] still waiting for: \${!_pending[*]}" >&2
      _last_diag=\$_now
    fi
    for _cert_path in "\${!_pending[@]}"; do
      if sudo -u corgi test -f "\$_cert_path" 2>/dev/null; then
        echo "  Certificate: \${_pending[\$_cert_path]}"
        unset '_pending[\$_cert_path]'
      fi
    done
    if (( \${#_pending[@]} > 0 )); then sleep 3; fi
  done
}

# Stop any running instances (services may be enabled and crash-looping from a prior attempt)
if command -v systemctl >/dev/null 2>&1; then
  echo "Stopping any running credo services..."
  sudo systemctl stop credo-vigil credo-shepherd credo-corgi 2>/dev/null || true
  # Also disable auto-restart during bootstrap so systemd doesn't interfere
  sudo systemctl mask --runtime credo-vigil credo-shepherd credo-corgi 2>/dev/null || true
fi

# Ensure corgi cert store dirs exist with correct ownership (install creates certs/ not store/).
# store/ gets setgid+credo-cert so archive/ and its contents inherit the group automatically.
sudo mkdir -p "\$CORGI_DIR/store/live"
sudo chown corgi:credo-cert "\$CORGI_DIR/store" "\$CORGI_DIR/store/live"
sudo chmod 2750 "\$CORGI_DIR/store" "\$CORGI_DIR/store/live"
# Fix any existing archive files from previous bootstrap runs.
if sudo test -d "\$CORGI_DIR/store/archive"; then
  sudo chown -R corgi:credo-cert "\$CORGI_DIR/store/archive"
fi

touch "\$VIGIL_LOG" "\$SHEPHERD_LOG" "\$CORGI_BOOT_LOG" "\$CORGI_LOG"

echo ""
echo "=== Step 1/5: Starting vigil in bootstrap mode..."
# Use bash -c so the service user cds into its own dir (PID file is written relative to cwd)
sudo -u vigil bash -c "cd \$VIGIL_DIR && VIGIL_CONFIG_PATH=\$VIGIL_CONFIG_PATH \$VIGIL_EXEC bootstrap" >> "\$VIGIL_LOG" 2>&1 &
VPID=\$!; TRACKED_PIDS+=(\$VPID)
VIGIL_SECRET=""
capture_from_log "\$VIGIL_LOG" 90 VIGIL_SECRET 'Vigil bootstrap secret: ([a-f0-9]{64})'
echo "  Vigil secret captured."

echo ""
echo "=== Step 2/5: Starting shepherd in bootstrap mode..."
sudo -u shepherd bash -c "cd \$SHEPHERD_DIR && SHEPHERD_CONFIG_PATH=\$SHEPHERD_CONFIG_PATH \$SHEPHERD_EXEC bootstrap server --vigil-secret \$VIGIL_SECRET" >> "\$SHEPHERD_LOG" 2>&1 &
SPID=\$!; TRACKED_PIDS+=(\$SPID)
ADMIN_TOKEN=""
capture_from_log "\$SHEPHERD_LOG" 90 ADMIN_TOKEN 'Shepherd bootstrap admin token: ([a-f0-9]{64})'
echo "  Admin token captured."

echo ""
echo "=== Step 3/5: Starting corgi in bootstrap mode..."
sudo -u corgi bash -c "cd \$CORGI_DIR && CORGI_CONFIG_PATH=\$CORGI_CONFIG_PATH \$CORGI_EXEC bootstrap" >> "\$CORGI_BOOT_LOG" 2>&1 &
CPID=\$!; TRACKED_PIDS+=(\$CPID)
CORGI_TOKEN="" CORGI_FINGERPRINT="" CORGI_READY=""
capture_from_log "\$CORGI_BOOT_LOG" 90 \
  CORGI_TOKEN       'Corgi bootstrap token:[[:space:]]+([a-f0-9]{64})' \
  CORGI_FINGERPRINT 'Corgi bootstrap fingerprint: ([a-f0-9]{64})' \
  CORGI_READY       'Bootstrap HTTPS server listening'
echo "  Corgi token and fingerprint captured."

echo ""
echo "=== Step 4/5: Registering admin + enrolling corgi..."
# Admin cert+key go to temp paths on the remote; the local bootstrap script rsyncs them back.
REMOTE_ADMIN_CERT="/tmp/credo-admin-cert-\$\$.pem"
REMOTE_ADMIN_KEY="/tmp/credo-admin-key-\$\$.pem"
sudo -u shepherd bash -c "cd \$SHEPHERD_DIR && SHEPHERD_CONFIG_PATH=\$SHEPHERD_CONFIG_PATH \$SHEPHERD_EXEC bootstrap admin --admin-token \$ADMIN_TOKEN --identity-uri \$ADMIN_IDENTITY_URI --out-cert \$REMOTE_ADMIN_CERT --out-key \$REMOTE_ADMIN_KEY --domain \$DOMAIN"

sudo -u shepherd bash -c "cd \$SHEPHERD_DIR && SHEPHERD_CONFIG_PATH=\$SHEPHERD_CONFIG_PATH \$SHEPHERD_EXEC bootstrap corgi --admin-token \$ADMIN_TOKEN --name \$CORGI_NAME --token \$CORGI_TOKEN --fingerprint \$CORGI_FINGERPRINT --identity-uri \$CORGI_IDENTITY_URI --corgi-url https://127.0.0.1:\${CORGI_PORT}"

if [[ "\$WANT_DASHBOARD" == "true" ]]; then
  echo ""
  echo "=== Adding dashboard service account..."
  if sudo -u shepherd bash -c "jq -e '.accounts[] | select(.name == \"dashboard\")' \"\$SHEPHERD_ACCOUNTS\"" >/dev/null 2>&1; then
    echo "  Dashboard account already exists, skipping."
  else
    sudo -u shepherd bash -c "jq --arg id \"\$DASHBOARD_ACCOUNT_ID\" --arg uri \"\$DASHBOARD_IDENTITY_URI\" '.accounts += [{id: \\\$id, name: \"dashboard\", displayName: \"Dashboard Service\", role: \"operator\", active: true, identities: [\\\$uri], notes: \"\", createdAt: null}]' \"\$SHEPHERD_ACCOUNTS\" > \"\$SHEPHERD_ACCOUNTS.tmp\""
    sudo -u shepherd mv "\$SHEPHERD_ACCOUNTS.tmp" "\$SHEPHERD_ACCOUNTS"
    echo "  Dashboard service account added (role: operator)."
  fi
fi

echo ""
echo "=== Step 5/5: Restarting in server mode, waiting for certs..."
kill "\$CPID" 2>/dev/null || true
sleep 0.3
sudo -u corgi bash -c "cd \$CORGI_DIR && CORGI_CONFIG_PATH=\$CORGI_CONFIG_PATH \$CORGI_EXEC server start" >> "\$CORGI_LOG" 2>&1 &
CPID2=\$!; TRACKED_PIDS+=(\$CPID2)
local_corgi_live="\$CORGI_DIR/store/live"
_t=\$(date +%s)
_cert_args=(
  "\$VIGIL_HOSTNAME:\${local_corgi_live}/\${VIGIL_HOSTNAME}/fullchain.pem"
  "\$SHEPHERD_HOSTNAME:\${local_corgi_live}/\${SHEPHERD_HOSTNAME}/fullchain.pem"
  "\$CORGI_HOSTNAME:\${local_corgi_live}/\${CORGI_HOSTNAME}/fullchain.pem"
)
if [[ "\$WANT_DASHBOARD" == "true" ]]; then
  _cert_args+=("$DASHBOARD_HOSTNAME:\${local_corgi_live}/$DASHBOARD_HOSTNAME/fullchain.pem")
fi
wait_for_certs "\$_t" "\${_cert_args[@]}"

kill "\$VPID" "\$SPID" 2>/dev/null || true; sleep 0.3

echo ""
echo "=== Bootstrap complete!"
echo "  vigil    log: \$VIGIL_LOG"
echo "  shepherd log: \$SHEPHERD_LOG"
echo "  corgi    log: \$CORGI_LOG"
echo "CREDO_REMOTE_ADMIN_CERT=\$REMOTE_ADMIN_CERT"
echo "CREDO_REMOTE_ADMIN_KEY=\$REMOTE_ADMIN_KEY"
echo ""

# Hand off to systemctl if available; otherwise detach background processes.
if command -v systemctl >/dev/null 2>&1 && sudo systemctl is-enabled credo-vigil >/dev/null 2>&1; then
  echo "Starting services via systemctl..."
  sudo systemctl unmask credo-vigil credo-shepherd credo-corgi 2>/dev/null || true
  sudo systemctl start credo-vigil credo-shepherd credo-corgi
  echo "Services started. They will persist across reboots."
else
  echo "systemctl unit files not found — starting as detached background processes."
  sudo -u vigil    bash -c "cd \$VIGIL_DIR    && nohup VIGIL_CONFIG_PATH=\$VIGIL_CONFIG_PATH       \$VIGIL_EXEC    server start >> \$VIGIL_LOG    2>&1 &"
  VPID2=\$!
  sudo -u shepherd bash -c "cd \$SHEPHERD_DIR && nohup SHEPHERD_CONFIG_PATH=\$SHEPHERD_CONFIG_PATH \$SHEPHERD_EXEC server start >> \$SHEPHERD_LOG 2>&1 &"
  SPID2=\$!
  disown "\$VPID2" "\$SPID2" "\$CPID2" 2>/dev/null || true
  echo "  vigil PID:    \$VPID2"
  echo "  shepherd PID: \$SPID2"
  echo "  corgi PID:    \$CPID2"
  echo "Run 'sudo systemctl start credo-vigil credo-shepherd credo-corgi' to manage via systemd instead."
fi

if [[ "\$WANT_DASHBOARD" == "true" ]]; then
  echo ""
  echo "=== Creating admin dashboard user..."
  if [[ -x "\$DASHBOARD_DIR/dashboard" ]]; then
    cd "\$DASHBOARD_DIR"
    if sudo -u dashboard ./dashboard user create \
         --account  "\$ADMIN_USERNAME" \
         --email    "\$ADMIN_EMAIL" \
         --name     "\$ADMIN_DISPLAY_NAME" \
         --identity "\$ADMIN_IDENTITY_URI"; then
      echo "  User created. Save the enrollment URL above."
    else
      echo "  User already exists, continuing."
    fi
  else
    echo "  WARNING: \$DASHBOARD_DIR/dashboard not found — deploy dashboard before running enrollment."
  fi

  echo ""
  echo "=== Starting dashboard service..."
  if command -v systemctl >/dev/null 2>&1 && sudo systemctl is-enabled credo-dashboard >/dev/null 2>&1; then
    sudo systemctl unmask credo-dashboard 2>/dev/null || true
    sudo systemctl start credo-dashboard
    echo "  Dashboard started via systemctl."
  else
    echo "  No systemd unit active — start manually:"
    echo "    cd \$DASHBOARD_DIR && sudo -u dashboard ./dashboard server start"
  fi
fi
REMOTE_SCRIPT_EOF

  # Upload the local script to the remote via rsync, then execute it
  local ssh_e="ssh -p ${REMOTE_PORT}${REMOTE_SSH_OPTS:+ }${REMOTE_SSH_OPTS}"
  echo "[bootstrap] Uploading remote bootstrap script to $REMOTE_HOST..."
  if [[ "$REMOTE_HOST" == "local" || "$REMOTE_HOST" == "localhost" || "$REMOTE_HOST" == "127.0.0.1" ]]; then
    cp "$local_script" "$remote_script"
  else
    # shellcheck disable=SC2086
    rsync -az -e "$ssh_e" "$local_script" "${REMOTE_HOST}:${remote_script}"
  fi
  rm -f "$local_script"

  echo "[bootstrap] Executing bootstrap script on $REMOTE_HOST..."
  local tee_out
  tee_out=$(mktemp /tmp/credo-bootstrap-tee-XXXXXX)
  if [[ "$REMOTE_HOST" == "local" || "$REMOTE_HOST" == "localhost" || "$REMOTE_HOST" == "127.0.0.1" ]]; then
    bash "$remote_script" 2>&1 | tee "$tee_out" || true; rm -f "$remote_script"
  else
    # Stream output in real-time via tee so progress is visible, and capture for parsing.
    # || true allows Phase 4 health checks to run even when the bootstrap script fails.
    # shellcheck disable=SC2086
    ssh -p "$REMOTE_PORT" $REMOTE_SSH_OPTS "$REMOTE_HOST" "bash '$remote_script'; rm -f '$remote_script'" 2>&1 | tee "$tee_out" || true
  fi
  # Extract remote paths for admin cert/key, then rsync them to local.
  local remote_admin_cert remote_admin_key
  remote_admin_cert=$(grep '^CREDO_REMOTE_ADMIN_CERT=' "$tee_out" | tail -1 | cut -d= -f2-)
  remote_admin_key=$(grep  '^CREDO_REMOTE_ADMIN_KEY='  "$tee_out" | tail -1 | cut -d= -f2-)
  rm -f "$tee_out"
  if [[ -n "$remote_admin_cert" && -n "$remote_admin_key" ]]; then
    echo "[bootstrap] Fetching admin credentials from remote..."
    mkdir -p "$(dirname "$ADMIN_OUT_CERT")" "$(dirname "$ADMIN_OUT_KEY")"
    # shellcheck disable=SC2086
    rsync -az -e "$ssh_e" "${REMOTE_HOST}:${remote_admin_cert}" "$ADMIN_OUT_CERT"
    # shellcheck disable=SC2086
    rsync -az -e "$ssh_e" "${REMOTE_HOST}:${remote_admin_key}"  "$ADMIN_OUT_KEY"
    chmod 600 "$ADMIN_OUT_KEY"
    echo "[bootstrap] Admin cert: $ADMIN_OUT_CERT"
    echo "[bootstrap] Admin key:  $ADMIN_OUT_KEY"
    # shellcheck disable=SC2086
    ssh -p "$REMOTE_PORT" $REMOTE_SSH_OPTS "$REMOTE_HOST" "rm -f '$remote_admin_cert' '$remote_admin_key'" 2>/dev/null || true
  else
    echo "[bootstrap] WARNING: admin credentials not found in remote output." >&2
  fi
}

# ---------------------------------------------------------------------------
# Phase 4 — Health verification
# ---------------------------------------------------------------------------

phase_verify() {
  phase "4 - Health verification"

  if $DRY_RUN; then
    echo "[bootstrap] Dry run - skipping health checks."
    return
  fi

  local trust_pem="$LOCAL_CA_DIR/root-ecdsa/certs/root-ecdsa.cert.pem"
  local ca_arg=()
  [[ -f "$trust_pem" ]] && ca_arg=(--cacert "$trust_pem")

  local all_ok=true
  local is_remote=false
  [[ "$REMOTE_HOST" != "local" && "$REMOTE_HOST" != "localhost" && "$REMOTE_HOST" != "127.0.0.1" ]] && is_remote=true

  check_health() {
    local label="$1" unit="$2" url="$3" attempts="${4:-1}" ok_codes="${5:-200}"
    local code
    for (( i=1; i<=attempts; i++ )); do
      if $is_remote; then
        code=$(remote_run "curl -s -o /dev/null -w '%{http_code}' --max-time 10 --cacert '$CA_TRUST_PATH' '$url' 2>/dev/null || echo 000" 2>/dev/null | tail -1 || echo "000")
      else
        code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 10 "${ca_arg[@]}" "$url" 2>/dev/null || echo "000")
      fi
      [[ " $ok_codes " == *" $code "* ]] && break
      (( i < attempts )) && sleep 5
    done
    if [[ " $ok_codes " == *" $code "* ]]; then
      printf '[bootstrap]   OK  %s (%s) HTTP %s\n' "$label" "$url" "$code"
    else
      printf '[bootstrap]   FAIL %s (%s) - HTTP %s\n' "$label" "$url" "$code"
      all_ok=false
      if $is_remote; then
        printf '[bootstrap]   --- journal: %s ---\n' "$unit"
        remote_run "journalctl -u '$unit' -n 20 --no-pager 2>/dev/null || true" \
          | sed 's/^/[bootstrap]   | /'
      fi
    fi
  }

  echo "[bootstrap] Checking health endpoints (retrying up to 6x over 30s)..."
  sleep 5

  check_health "vigil"    "credo-vigil"    "https://$VIGIL_HOSTNAME:$VIGIL_PORT/health"               6 "200 401"
  check_health "shepherd" "credo-shepherd" "https://$SHEPHERD_HOSTNAME:$SHEPHERD_DASHBOARD_PORT/health" 6 "200"

  # Lazy-load dashboard vars (in case --phase 4 is run standalone)
  [[ -z "$DASHBOARD_HOSTNAME" ]] && DASHBOARD_HOSTNAME=$(_df '.dashboard.hostname' '')
  [[ -z "$DASHBOARD_PORT"     ]] && DASHBOARD_PORT=$(    _df '.dashboard.port'     '7030')

  if [[ -n "${DASHBOARD_HOSTNAME:-}" ]]; then
    # /api/health requires auth; hit / and accept login-page redirect or auth challenge
    check_health "dashboard" "credo-dashboard" \
      "https://$DASHBOARD_HOSTNAME:$DASHBOARD_PORT/" 6 "200 302 401"
  fi

  if $all_ok; then
    echo "[bootstrap] All health checks passed."
  else
    echo "[bootstrap] Some checks failed (see journal output above)."
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

print_help() {
  cat >&2 <<'EOF'
scripts/bootstrap — 4-phase credo bootstrap orchestrator

Phases:
  0  Collect configuration answers (interactive or --auto)
  1  PKI ceremony — generate root + intermediate CA locally
  2  Push service configs and CA files to remote host
  3  Run bootstrap sequence on remote host (vigil→shepherd→corgi)
  4  Health verify via curl

Usage:
  scripts/bootstrap [options]

Options:
  --auto               Non-interactive; reads bootstrap.json (or bootstrap-default.json)
  --dry-run            Generate configs only; do not push files or run services
  --skip-ceremony      Skip Phase 1 (CA files must already exist locally)
  --phase <N>          Run only phase N (0,1,2,3,4); answers still collected first
  --config <path>      Path to .install.json (default: .install.json in repo root)
  --bootstrap <path>   Path to bootstrap answers file (default: bootstrap.json)
  --help               Show this help

Environment:
  CREDO_ROOT_CA_PASSPHRASE  Root CA passphrase for non-interactive ceremony

Examples:
  scripts/bootstrap                             # fully interactive
  scripts/bootstrap --dry-run                   # generate configs only
  scripts/bootstrap --auto                      # non-interactive (needs bootstrap.json)
  CREDO_ROOT_CA_PASSPHRASE=s3cr3t scripts/bootstrap --auto
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  command -v jq >/dev/null 2>&1 || die "jq is required (brew install jq / apt install jq)"

  while (( $# > 0 )); do
    case "$1" in
      --help|-h)       print_help; exit 0 ;;
      --auto)          AUTO=true ;;
      --dry-run)       DRY_RUN=true ;;
      --skip-ceremony) SKIP_CEREMONY=true ;;
      --phase)         PHASE_ONLY="${2:-}"; shift ;;
      --config)        INSTALL_CONFIG="${2:-}"; shift ;;
      --bootstrap)     BOOTSTRAP_JSON="${2:-}"; shift ;;
      *) die "Unknown option: $1" ;;
    esac
    shift
  done

  banner "Credo Bootstrap"
  if $DRY_RUN; then echo "[bootstrap] DRY RUN mode"; fi
  if $AUTO;    then echo "[bootstrap] AUTO mode (non-interactive)"; fi

  echo "[bootstrap] config: $INSTALL_CONFIG" >&2
  load_install_config
  echo "[bootstrap] host: $REMOTE_HOST" >&2

  if [[ -z "$PHASE_ONLY" || "$PHASE_ONLY" == "0" ]]; then
    phase "0 - Answer collection"
    collect_answers
  fi

  if [[ -z "$PHASE_ONLY" || "$PHASE_ONLY" == "1" ]]; then
    phase_ceremony
  fi

  if [[ -z "$PHASE_ONLY" || "$PHASE_ONLY" == "2" ]]; then
    phase_config
  fi

  if [[ -z "$PHASE_ONLY" || "$PHASE_ONLY" == "3" ]]; then
    phase_bootstrap
  fi

  if [[ -z "$PHASE_ONLY" || "$PHASE_ONLY" == "4" ]]; then
    phase_verify
  fi

  banner "Bootstrap complete"
  echo "[bootstrap] Answers saved: $BOOTSTRAP_JSON"
  echo "[bootstrap] Start services: sudo systemctl start credo-vigil credo-shepherd credo-corgi"
  echo ""
}

main "$@"
