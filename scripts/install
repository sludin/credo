#!/usr/bin/env bash
set -euo pipefail

if (( BASH_VERSINFO[0] < 4 )); then
  echo "[install] Requires bash 4+. macOS users: brew install bash" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

REPO_DIR=$(cd "$(dirname "$0")/.." && pwd)
CORGI_DIR="$REPO_DIR/corgi"
VIGIL_DIR="$REPO_DIR/vigil"
SHEPHERD_DIR="$REPO_DIR/shepherd"
CONFIG_PATH="$REPO_DIR/.install.json"
DRY_RUN=false
PARALLEL=false
PRINT_BUILD_CMD=false
TARGETS=()

# Default file lists per service (space-separated, used when config omits "files")
# All referenced via indirect expansion: ${!default_var:-}
# shellcheck disable=SC2034
DEFAULT_FILES_shepherd="shepherd examples"
# shellcheck disable=SC2034
DEFAULT_FILES_vigil="vigil examples"
# shellcheck disable=SC2034
DEFAULT_FILES_dashboard="dist package.json package-lock.json scripts dashboard"
# shellcheck disable=SC2034
DEFAULT_FILES_enroll="dist package.json"
# shellcheck disable=SC2034
DEFAULT_FILES_wizard="examples lib bootstrap-wizard"
DEFAULT_FILES_corgi="examples corgi"

STAGING_DIRS=()
STAGING_DIR=""  # output variable set by build functions (avoids subshell)

declare -A SEEN_LABELS=()
JOB_LABELS=()
JOB_TYPES=()
JOB_KEYS=()

# ---------------------------------------------------------------------------
# Cleanup
# ---------------------------------------------------------------------------

cleanup() {
  local d
  for d in "${STAGING_DIRS[@]+"${STAGING_DIRS[@]}"}"; do
    rm -rf "$d"
  done
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# SSH helpers
# ---------------------------------------------------------------------------

is_local() { [[ "$1" == "local" || "$1" == "localhost" || "$1" == "127.0.0.1" ]]; }

format_dest() {
  local host="$1" remote_dir="$2"
  if is_local "$host"; then echo "$remote_dir (local)"; else echo "$host:$remote_dir"; fi
}

ssh_run() {
  local host="$1" port="$2" ssh_opts="$3" cmd="$4"
  # shellcheck disable=SC2086
  ssh -p "$port" $ssh_opts "$host" "$cmd"
}

run_cmd() {
  local host="$1" port="$2" ssh_opts="$3" cmd="$4"
  if is_local "$host"; then
    bash -c "$cmd"
  else
    ssh_run "$host" "$port" "$ssh_opts" "$cmd"
  fi
}

ensure_dir() {
  local host="$1" port="$2" ssh_opts="$3" dir="$4" sudo_rsync="${5:-false}" remote_user="${6:-}"
  if [[ "$sudo_rsync" == "true" ]]; then
    # Create with root sudo, then hand ownership to remote_user so rsync can write.
    # Using sudo -u <user> mkdir would fail: the service user can't create /var/apps/credo.
    if [[ -n "$remote_user" ]]; then
      run_cmd "$host" "$port" "$ssh_opts" \
        "sudo mkdir -p '$dir' && sudo chown '$remote_user' '$dir'" || {
        echo "[install] ERROR: could not create $dir on $host." >&2
        echo "[install] If service users don't exist yet, run: scripts/install setup" >&2
        return 1
      }
    else
      run_cmd "$host" "$port" "$ssh_opts" "sudo mkdir -p '$dir'" || return 1
    fi
  else
    run_cmd "$host" "$port" "$ssh_opts" "mkdir -p '$dir'" || return 1
  fi
}

npm_install_remote() {
  local host="$1" port="$2" ssh_opts="$3" dir="$4" remote_user="${5:-}"
  if is_local "$host"; then
    echo "[install] npm install --omit=dev (local)..."
  else
    echo "[install] npm install --omit=dev on $host..."
  fi
  if [[ -n "$remote_user" ]]; then
    run_cmd "$host" "$port" "$ssh_opts" "sudo -u '$remote_user' sh -c \"cd '$dir' && npm install --omit=dev\""
  else
    run_cmd "$host" "$port" "$ssh_opts" "cd '$dir' && npm install --omit=dev"
  fi
}

chown_dir() {
  local host="$1" port="$2" ssh_opts="$3" dir="$4" owner="$5"
  echo "[install] chown -R $owner $dir"
  run_cmd "$host" "$port" "$ssh_opts" "sudo chown -R '$owner' '$dir'"
}

chmod_dir() {
  local host="$1" port="$2" ssh_opts="$3" dir="$4" mode="$5"
  echo "[install] chmod $mode $dir"
  run_cmd "$host" "$port" "$ssh_opts" "sudo chmod '$mode' '$dir'"
}

run_post_deploy() {
  local host="$1" port="$2" ssh_opts="$3" dir="$4" cmd="$5"
  echo "[install] postDeploy: $cmd"
  run_cmd "$host" "$port" "$ssh_opts" "cd '$dir' && $cmd"
}

shell_escape_word() {
  printf '%q' "$1"
}

join_shell_words() {
  local out="" arg
  for arg in "$@"; do
    if [[ -n "$out" ]]; then out+=" "; fi
    out+="$(shell_escape_word "$arg")"
  done
  printf '%s' "$out"
}

validate_build_overrides() {
  local svc_json="$1" label="$2"

  if ! jq -e '
    (.buildOverrides // {}) as $bo
    | ($bo | type == "object")
    and (($bo.env // {}) | type == "object")
    and (($bo.env // {}) | all(to_entries[]?; .value | type == "string"))
    and (($bo.args // []) | type == "array")
    and (($bo.args // []) | all(.[]?; type == "string"))
  ' <<< "$svc_json" >/dev/null; then
    echo "[install] Invalid buildOverrides for $label: expected env object of strings and args array of strings" >&2
    return 1
  fi
}

# ---------------------------------------------------------------------------
# rsync
# ---------------------------------------------------------------------------

rsync_deploy() {
  local staging_dir="$1" host="$2" remote_dir="$3" port="$4" ssh_opts="$5" rsync_opts="$6"
  local sudo_rsync="${7:-false}" remote_user="${8:-}"
  local args=(-avz --itemize-changes
    '--exclude=node_modules/'
    '--exclude=.env'
    '--exclude=.env.*'
  )
  if [[ "$sudo_rsync" == "true" ]]; then
    if [[ -n "$remote_user" ]]; then
      args+=(--rsync-path="sudo -u '$remote_user' rsync")
    else
      args+=(--rsync-path="sudo rsync")
    fi
  fi
  # shellcheck disable=SC2206
  if [[ -n "$rsync_opts" ]]; then args+=($rsync_opts); fi
  if $DRY_RUN; then args+=(--dry-run); fi

  if is_local "$host"; then
    # Trailing slash: sync contents of staging_dir, not the dir itself
    args+=("$staging_dir/" "$remote_dir/")
    if $DRY_RUN; then
      echo "[install] DRY RUN rsync → $remote_dir (local)"
    else
      echo "[install] rsync → $remote_dir (local)"
    fi
  else
    # shellcheck disable=SC2086
    local ssh_cmd="ssh -p $port $ssh_opts"
    args+=(-e "$ssh_cmd" "$staging_dir/" "$host:$remote_dir/")
    if $DRY_RUN; then
      echo "[install] DRY RUN rsync → $host:$remote_dir"
    else
      echo "[install] rsync → $host:$remote_dir"
    fi
  fi

  rsync "${args[@]}"
}

# ---------------------------------------------------------------------------
# TypeScript service staging
# Sets STAGING_DIR to the created path. Does NOT use command substitution so
# that STAGING_DIRS accumulates correctly in the current process.
# ---------------------------------------------------------------------------

build_ts_staging() {
  local service_dir="$1" service_name="$2" files_str="$3"
  local d
  d=$(mktemp -d "/tmp/credo-deploy-${service_name}-XXXXXX")
  chmod 755 "$d"
  STAGING_DIRS+=("$d")
  STAGING_DIR="$d"

  local sha version
  sha=$(git -C "$REPO_DIR" rev-parse --short HEAD)
  version=$(jq -r '.version' "$service_dir/package.json")
  printf 'export const VERSION = "%s-%s";\n' "$version" "$sha" \
    > "$service_dir/src/version.ts"

  echo "[install] Installing dependencies for $service_name..."
  (cd "$service_dir" && npm install) || return 1

  echo "[install] Building $service_name ($version-$sha)..."
  (cd "$service_dir" && npm run build) || return 1

  local entry src
  for entry in $files_str; do
    src="$service_dir/$entry"
    if [[ ! -e "$src" ]]; then
      echo "[install] Warning: declared file not found, skipping: $entry"
      continue
    fi
    mkdir -p "$d/$(dirname "$entry")"
    cp -r "$src" "$d/$entry"
  done

  echo "[install] Staging ready: $d"
}

# ---------------------------------------------------------------------------
# Shell service staging (no npm build — wizard and similar)
# Sets STAGING_DIR to the created path.
# ---------------------------------------------------------------------------

build_shell_staging() {
  local service_dir="$1" service_name="$2" files_str="$3"
  local d
  d=$(mktemp -d "/tmp/credo-deploy-${service_name}-XXXXXX")
  chmod 755 "$d"
  STAGING_DIRS+=("$d")
  STAGING_DIR="$d"

  local entry src
  for entry in $files_str; do
    src="$service_dir/$entry"
    if [[ ! -e "$src" ]]; then
      echo "[install] Warning: declared file not found, skipping: $entry"
      continue
    fi
    mkdir -p "$d/$(dirname "$entry")"
    cp -r "$src" "$d/$entry"
  done

  echo "[install] Staging ready: $d"
}

# ---------------------------------------------------------------------------
# Rust binary staging
# Sets STAGING_DIR to the created path.
# Requires cargo-zigbuild: cargo install cargo-zigbuild
# ---------------------------------------------------------------------------

build_rust_binary_staging() {
  local crate_dir="$1" binary_name="$2" arch="$3" profile="$4"
  local files_str="${5:-}" svc_json="${6:-}" label="${7:-$binary_name}"
  local d
  d=$(mktemp -d "/tmp/credo-deploy-${binary_name}-XXXXXX")
  chmod 755 "$d"
  STAGING_DIRS+=("$d")
  STAGING_DIR="$d"

  local -a build_env_assignments=()
  local -a build_extra_args=()
  local -a build_cmd=(cargo zigbuild --target "$arch")

  if [[ -n "$svc_json" ]]; then
    validate_build_overrides "$svc_json" "$label"

    local key value arg
    while IFS=$'\t' read -r key value; do
      [[ -n "$key" ]] && build_env_assignments+=("$key=$value")
    done < <(jq -r '.buildOverrides.env // {} | to_entries[] | [.key, .value] | @tsv' <<< "$svc_json")

    while IFS= read -r arg; do
      [[ -n "$arg" ]] && build_extra_args+=("$arg")
    done < <(jq -r '.buildOverrides.args // [] | .[]' <<< "$svc_json")
  fi

  [[ "$profile" == "release" ]] && build_cmd+=(--release)
  if [[ ${#build_extra_args[@]} -gt 0 ]]; then
    build_cmd+=("${build_extra_args[@]}")
  fi

  local printed_cmd
  printed_cmd="cd $(shell_escape_word "$crate_dir") &&"
  if [[ ${#build_env_assignments[@]} -gt 0 ]]; then
    printed_cmd+=" $(join_shell_words env "${build_env_assignments[@]}" "${build_cmd[@]}")"
  else
    printed_cmd+=" $(join_shell_words "${build_cmd[@]}")"
  fi

  echo "[install] Building $binary_name for $arch ($profile)..."
  if $PRINT_BUILD_CMD; then
    echo "[install][$label] BUILD_CMD: $printed_cmd"
  fi

  if [[ ${#build_env_assignments[@]} -gt 0 ]]; then
    (cd "$crate_dir" && env "${build_env_assignments[@]}" "${build_cmd[@]}") || {
      echo "[install][$label] BUILD_CMD (failed): $printed_cmd" >&2
      return 1
    }
  else
    (cd "$crate_dir" && "${build_cmd[@]}") || {
      echo "[install][$label] BUILD_CMD (failed): $printed_cmd" >&2
      return 1
    }
  fi

  cp "$REPO_DIR/target/$arch/$profile/$binary_name" "$d/$binary_name"

  local entry src
  for entry in $files_str; do
    [[ "$entry" == "$binary_name" ]] && continue
    src="$crate_dir/$entry"
    if [[ ! -e "$src" ]]; then
      echo "[install] Warning: declared file not found, skipping: $entry"
      continue
    fi
    mkdir -p "$d/$(dirname "$entry")"
    cp -r "$src" "$d/$entry"
  done

  echo "[install] Staging ready: $d"
}

# ---------------------------------------------------------------------------
# Core deploy: Rust binary (no npm install on remote)
# ---------------------------------------------------------------------------

_deploy_rust() {
  local label="$1" crate_dir="$2" binary="$3" arch="$4" profile="$5"
  local host="$6" remote_dir="$7" port="$8" ssh_opts="$9" rsync_opts="${10}"
  local owner="${11}" post_deploy="${12}" files_str="${13:-}" dir_mode="${14:-}"
  local sudo_rsync="${15:-false}" remote_user="${16:-}" svc_json="${17:-}"

  build_rust_binary_staging "$crate_dir" "$binary" "$arch" "$profile" "$files_str" "$svc_json" "$label"
  local staging_dir="$STAGING_DIR"

  if ! $DRY_RUN; then ensure_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$sudo_rsync" "$remote_user"; fi
  rsync_deploy "$staging_dir" "$host" "$remote_dir" "$port" "$ssh_opts" "$rsync_opts" "$sudo_rsync" "$remote_user"

  if ! $DRY_RUN; then
    if [[ -n "$owner" ]]; then chown_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$owner"; fi
    if [[ -n "$dir_mode" ]]; then chmod_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$dir_mode"; fi
    if [[ -n "$post_deploy" ]]; then run_post_deploy "$host" "$port" "$ssh_opts" "$remote_dir" "$post_deploy"; fi
  fi

  if $DRY_RUN; then
    echo "[install] DRY RUN complete: $label → $(format_dest "$host" "$remote_dir")"
  else
    echo "[install] Done: $label → $(format_dest "$host" "$remote_dir")"
  fi
}

# ---------------------------------------------------------------------------
# Core deploy: TypeScript service (npm install on remote)
# ---------------------------------------------------------------------------

_deploy_ts() {
  local label="$1" service_key="$2" files_str="$3"
  local host="$4" remote_dir="$5" port="$6" ssh_opts="$7" rsync_opts="$8"
  local owner="$9" post_deploy="${10}" dir_mode="${11:-}"
  local sudo_rsync="${12:-false}" remote_user="${13:-}"

  local service_dir="$REPO_DIR/$service_key"
  build_ts_staging "$service_dir" "$service_key" "$files_str"
  local staging_dir="$STAGING_DIR"

  if ! $DRY_RUN; then ensure_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$sudo_rsync" "$remote_user"; fi
  rsync_deploy "$staging_dir" "$host" "$remote_dir" "$port" "$ssh_opts" "$rsync_opts" "$sudo_rsync" "$remote_user"

  if ! $DRY_RUN; then
    npm_install_remote "$host" "$port" "$ssh_opts" "$remote_dir" "$remote_user"
    if [[ -n "$owner" ]]; then chown_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$owner"; fi
    if [[ -n "$dir_mode" ]]; then chmod_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$dir_mode"; fi
    if [[ -n "$post_deploy" ]]; then run_post_deploy "$host" "$port" "$ssh_opts" "$remote_dir" "$post_deploy"; fi
  fi

  if $DRY_RUN; then
    echo "[install] DRY RUN complete: $label → $(format_dest "$host" "$remote_dir")"
  else
    echo "[install] Done: $label → $(format_dest "$host" "$remote_dir")"
  fi
}

# ---------------------------------------------------------------------------
# Core deploy: Shell service (no npm install — wizard and similar)
# ---------------------------------------------------------------------------

_deploy_shell() {
  local label="$1" service_key="$2" files_str="$3"
  local host="$4" remote_dir="$5" port="$6" ssh_opts="$7" rsync_opts="$8"
  local owner="$9" post_deploy="${10}" dir_mode="${11:-}"
  local sudo_rsync="${12:-false}" remote_user="${13:-}"

  local service_dir="$REPO_DIR/$service_key"
  build_shell_staging "$service_dir" "$service_key" "$files_str"
  local staging_dir="$STAGING_DIR"

  if ! $DRY_RUN; then ensure_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$sudo_rsync" "$remote_user"; fi
  rsync_deploy "$staging_dir" "$host" "$remote_dir" "$port" "$ssh_opts" "$rsync_opts" "$sudo_rsync" "$remote_user"

  if ! $DRY_RUN; then
    if [[ -n "$owner" ]]; then chown_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$owner"; fi
    if [[ -n "$dir_mode" ]]; then chmod_dir "$host" "$port" "$ssh_opts" "$remote_dir" "$dir_mode"; fi
    if [[ -n "$post_deploy" ]]; then run_post_deploy "$host" "$port" "$ssh_opts" "$remote_dir" "$post_deploy"; fi
  fi

  if $DRY_RUN; then
    echo "[install] DRY RUN complete: $label → $(format_dest "$host" "$remote_dir")"
  else
    echo "[install] Done: $label → $(format_dest "$host" "$remote_dir")"
  fi
}

# ---------------------------------------------------------------------------
# Deploy a named service (shepherd, vigil, dashboard, enroll, wizard)
# Reads config, dispatches to _deploy_rust or _deploy_ts based on rustTarget.
# ---------------------------------------------------------------------------

deploy_service() {
  local service_key="$1"
  local label="${2:-$service_key}"

  local svc_json
  svc_json=$(jq -c --arg k "$service_key" '.[$k]' "$CONFIG_PATH")

  local host remote_dir port ssh_opts rsync_opts owner post_deploy rust_target rust_profile files_str dir_mode sudo_rsync remote_user remote_group service_name restart_mode use_sudo
  host=$(jq -r '.host // empty' <<< "$svc_json")
  remote_dir=$(jq -r '.remoteDir // empty' <<< "$svc_json")
  port=$(jq -r '.sshPort // 22' <<< "$svc_json")
  ssh_opts=$(jq -r '.sshOpts // ""' <<< "$svc_json")
  rsync_opts=$(jq -r '.rsyncOpts // .rsyncopts // ""' <<< "$svc_json")
  owner=$(jq -r '.owner // empty' <<< "$svc_json")
  post_deploy=$(jq -r '.postDeploy // empty' <<< "$svc_json")
  rust_target=$(jq -r '.rustTarget // empty' <<< "$svc_json")
  rust_profile=$(jq -r '.rustProfile // "release"' <<< "$svc_json")
  files_str=$(jq -r '.files[]? // empty' <<< "$svc_json" | tr '\n' ' ')
  dir_mode=$(jq -r '.dirMode // empty' <<< "$svc_json")
  sudo_rsync=$(jq -r '.sudoRsync // false' <<< "$svc_json")
  remote_user=$(jq -r '.remoteUser // empty' <<< "$svc_json")
  remote_group=$(jq -r '.remoteGroup // empty' <<< "$svc_json")
  service_name=$(jq -r '.serviceName // empty' <<< "$svc_json")
  restart_mode=$(jq -r '.restartMode // "restart"' <<< "$svc_json")
  use_sudo=$(jq -r 'if .useSudo == false then "false" else "true" end' <<< "$svc_json")
  if [[ "$use_sudo" == "false" ]]; then sudo_rsync="false"; fi
  if [[ -z "$owner" && -n "$remote_user" && -n "$remote_group" ]]; then
    owner="${remote_user}:${remote_group}"
  fi
  if [[ -z "$post_deploy" && -n "$service_name" && "$restart_mode" != "none" ]]; then
    if [[ "$use_sudo" == "false" ]]; then
      post_deploy="systemctl $restart_mode '$service_name'"
    else
      post_deploy="sudo systemctl $restart_mode '$service_name'"
    fi
  fi

  if [[ -n "$rust_target" ]]; then
    local crate_dir binary
    case "$service_key" in
      shepherd) crate_dir="$SHEPHERD_DIR"; binary="shepherd" ;;
      vigil)    crate_dir="$VIGIL_DIR";    binary="vigil" ;;
      *)
        echo "[install] Rust build not supported for service: $service_key" >&2
        return 1 ;;
    esac
    if [[ -z "${files_str// /}" ]]; then
      local default_var="DEFAULT_FILES_${service_key}"
      files_str="${!default_var:-}"
    fi
    _deploy_rust "$label" "$crate_dir" "$binary" "$rust_target" "$rust_profile" \
      "$host" "$remote_dir" "$port" "$ssh_opts" "$rsync_opts" \
      "$owner" "$post_deploy" "$files_str" "$dir_mode" "$sudo_rsync" "$remote_user" "$svc_json"
  elif [[ -f "$REPO_DIR/$service_key/package.json" ]]; then
    if [[ -z "${files_str// /}" ]]; then
      local default_var="DEFAULT_FILES_${service_key}"
      files_str="${!default_var:-$DEFAULT_FILES_shepherd}"
    fi
    _deploy_ts "$label" "$service_key" "$files_str" \
      "$host" "$remote_dir" "$port" "$ssh_opts" "$rsync_opts" \
      "$owner" "$post_deploy" "$dir_mode" "$sudo_rsync" "$remote_user"
  else
    if [[ -z "${files_str// /}" ]]; then
      local default_var="DEFAULT_FILES_${service_key}"
      files_str="${!default_var:-}"
    fi
    _deploy_shell "$label" "$service_key" "$files_str" \
      "$host" "$remote_dir" "$port" "$ssh_opts" "$rsync_opts" \
      "$owner" "$post_deploy" "$dir_mode" "$sudo_rsync" "$remote_user"
  fi
}

# ---------------------------------------------------------------------------
# Deploy a corgi by name
# ---------------------------------------------------------------------------

deploy_corgi_by_name() {
  local name="$1"
  local label="corgi/$name"

  local exists
  exists=$(jq -r --arg n "$name" '.corgis[]? | select(.name == $n) | .name' "$CONFIG_PATH")
  if [[ -z "$exists" ]]; then
    local available
    available=$(jq -r '.corgis[]?.name' "$CONFIG_PATH" | tr '\n' ' ')
    echo "[install] Corgi '$name' not found. Available: ${available:-(none configured)}" >&2
    return 1
  fi

  local corgi_json
  corgi_json=$(jq -c --arg n "$name" '.corgis[] | select(.name == $n)' "$CONFIG_PATH")

  local host remote_dir port ssh_opts rsync_opts owner post_deploy rust_target rust_profile files_str dir_mode sudo_rsync remote_user remote_group service_name restart_mode use_sudo
  host=$(jq -r '.host // empty' <<< "$corgi_json")
  remote_dir=$(jq -r '.remoteDir // empty' <<< "$corgi_json")
  port=$(jq -r '.sshPort // 22' <<< "$corgi_json")
  ssh_opts=$(jq -r '.sshOpts // ""' <<< "$corgi_json")
  rsync_opts=$(jq -r '.rsyncOpts // .rsyncopts // ""' <<< "$corgi_json")
  owner=$(jq -r '.owner // empty' <<< "$corgi_json")
  post_deploy=$(jq -r '.postDeploy // empty' <<< "$corgi_json")
  rust_target=$(jq -r '.rustTarget // empty' <<< "$corgi_json")
  rust_profile=$(jq -r '.rustProfile // "release"' <<< "$corgi_json")
  files_str=$(jq -r '.files[]?' <<< "$corgi_json" | tr '\n' ' ')
  dir_mode=$(jq -r '.dirMode // empty' <<< "$corgi_json")
  sudo_rsync=$(jq -r '.sudoRsync // false' <<< "$corgi_json")
  remote_user=$(jq -r '.remoteUser // empty' <<< "$corgi_json")
  remote_group=$(jq -r '.remoteGroup // empty' <<< "$corgi_json")
  service_name=$(jq -r '.serviceName // empty' <<< "$corgi_json")
  restart_mode=$(jq -r '.restartMode // "restart"' <<< "$corgi_json")
  use_sudo=$(jq -r '.useSudo // true' <<< "$corgi_json")
  if [[ "$use_sudo" == "false" ]]; then sudo_rsync="false"; fi
  if [[ -z "$owner" && -n "$remote_user" && -n "$remote_group" ]]; then
    owner="${remote_user}:${remote_group}"
  fi
  if [[ -z "$post_deploy" && -n "$service_name" && "$restart_mode" != "none" ]]; then
    if [[ "$use_sudo" == "false" ]]; then
      post_deploy="systemctl $restart_mode '$service_name'"
    else
      post_deploy="sudo systemctl $restart_mode '$service_name'"
    fi
  fi

  if [[ -n "$rust_target" ]]; then
    if [[ -z "${files_str// /}" ]]; then files_str="$DEFAULT_FILES_corgi"; fi
    _deploy_rust "$label" "$CORGI_DIR" "corgi" "$rust_target" "$rust_profile" \
      "$host" "$remote_dir" "$port" "$ssh_opts" "$rsync_opts" \
      "$owner" "$post_deploy" "$files_str" "$dir_mode" "$sudo_rsync" "$remote_user" "$corgi_json"
  else
    if [[ -z "${files_str// /}" ]]; then files_str="$DEFAULT_FILES_corgi"; fi
    _deploy_ts "$label" "corgi" "$files_str" \
      "$host" "$remote_dir" "$port" "$ssh_opts" "$rsync_opts" \
      "$owner" "$post_deploy" "$dir_mode" "$sudo_rsync" "$remote_user"
  fi
}

# ---------------------------------------------------------------------------
# Job queue
# ---------------------------------------------------------------------------

add_job() {
  local label="$1" type="$2" key="$3"
  if [[ -n "${SEEN_LABELS[$label]+set}" ]]; then
    echo "[install] Skipping duplicate target: $label" >&2
    return
  fi
  SEEN_LABELS["$label"]=1
  JOB_LABELS+=("$label")
  JOB_TYPES+=("$type")
  JOB_KEYS+=("$key")
}

run_job() {
  local i="$1"
  local type="${JOB_TYPES[$i]}" key="${JOB_KEYS[$i]}"
  case "$type" in
    service) deploy_service "$key" "${JOB_LABELS[$i]}" ;;
    corgi)   deploy_corgi_by_name "$key" ;;
    scripts) deploy_scripts ;;
  esac
}

execute_jobs() {
  local failures=()

  if $PARALLEL; then
    local pids=() i
    for i in "${!JOB_LABELS[@]}"; do
      run_job "$i" &
      pids+=($!)
    done
    for i in "${!pids[@]}"; do
      if ! wait "${pids[$i]}"; then
        failures+=("${JOB_LABELS[$i]}")
      fi
    done
  else
    local i
    for i in "${!JOB_LABELS[@]}"; do
      if ! run_job "$i"; then
        echo "[install] ERROR (${JOB_LABELS[$i]}): deploy failed" >&2
        failures+=("${JOB_LABELS[$i]}")
      fi
    done
  fi

  if [[ ${#failures[@]} -gt 0 ]]; then
    printf '\n[install] Completed with %d failure(s):\n' "${#failures[@]}"
    local f
    for f in "${failures[@]}"; do printf '  ✗ %s\n' "$f"; done
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Scripts deployment
# Rsyncs the repo's scripts/ directory to $base_dir/scripts/ on the remote.
# Called after service deploys so operators can run scripts/bootstrap there.
# ---------------------------------------------------------------------------

deploy_scripts() {
  local config_path="$CONFIG_PATH"
  [[ ! -f "$config_path" ]] && return 0

  local host port ssh_opts sudo_rsync first_remote_dir base_dir scripts_dir
  host="$(jq -r '(.shepherd // .vigil // .dashboard // .corgis[0]) | .host // empty' "$config_path")"
  port="$(jq -r '(.shepherd // .vigil // .dashboard // .corgis[0]) | .sshPort // 22' "$config_path")"
  ssh_opts="$(jq -r '(.shepherd // .vigil // .dashboard // .corgis[0]) | .sshOpts // ""' "$config_path")"
  sudo_rsync="$(jq -r '(.shepherd // .vigil // .dashboard // .corgis[0]) | .sudoRsync // false' "$config_path")"
  first_remote_dir="$(jq -r '(.shepherd // .vigil // .dashboard // .corgis[0]) | .remoteDir // empty' "$config_path")"
  base_dir="${first_remote_dir%/*}"
  [[ -z "$base_dir" ]] && base_dir="/var/apps/credo"
  scripts_dir="${base_dir}/scripts"

  [[ -z "$host" ]] && return 0

  echo "[install] scripts → $(format_dest "$host" "$scripts_dir")"
  ensure_dir "$host" "$port" "$ssh_opts" "$scripts_dir" "$sudo_rsync" || return 1

  local d
  d=$(mktemp -d "/tmp/credo-deploy-scripts-XXXXXX")
  STAGING_DIRS+=("$d")
  cp -r "$REPO_DIR/scripts/." "$d/"

  rsync_deploy "$d" "$host" "$scripts_dir" "$port" "$ssh_opts" "" "$sudo_rsync"
}

# ---------------------------------------------------------------------------
# Target expansion
# ---------------------------------------------------------------------------

expand_targets() {
  local token name svc
  for token in "${TARGETS[@]}"; do
    case "$token" in
      all)
        for svc in shepherd vigil dashboard enroll wizard; do
          if jq -e ".$svc" "$CONFIG_PATH" >/dev/null 2>&1; then
            add_job "$svc" "service" "$svc"
          fi
        done
        while IFS= read -r name; do
          if [[ -n "$name" ]]; then add_job "corgi/$name" "corgi" "$name"; fi
        done < <(jq -r '.corgis[]?.name' "$CONFIG_PATH")
        ;;
      shepherd|vigil|dashboard|enroll|wizard)
        if ! jq -e ".$token" "$CONFIG_PATH" >/dev/null 2>&1; then
          echo "[install] No '$token' section in .install.json" >&2
          exit 1
        fi
        add_job "$token" "service" "$token"
        ;;
      corgi)
        while IFS= read -r name; do
          if [[ -n "$name" ]]; then add_job "corgi/$name" "corgi" "$name"; fi
        done < <(jq -r '.corgis[]?.name' "$CONFIG_PATH")
        ;;
      corgi:*)
        name="${token#corgi:}"
        add_job "corgi/$name" "corgi" "$name"
        ;;
      scripts)
        add_job "scripts" "scripts" "scripts"
        ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Init subcommand — generate .install.json interactively
# ---------------------------------------------------------------------------

ask_init() {
  local prompt="$1" default="${2:-}" display
  if [[ -n "$default" ]]; then
    display="$prompt [$default]: "
  else
    display="$prompt: "
  fi
  local reply
  IFS= read -r -e -p "$display" reply </dev/tty || reply=""
  printf '%s' "${reply:-$default}"
}

ask_init_yn() {
  local prompt="$1" default="${2:-y}"
  local reply
  while true; do
    if [[ "$default" == "y" ]]; then
      printf '%s [Y/n]: ' "$prompt" >/dev/tty
    else
      printf '%s [y/N]: ' "$prompt" >/dev/tty
    fi
    read -r reply </dev/tty
    reply="${reply:-$default}"
    case "${reply,,}" in
      y|yes) printf 'y'; return ;;
      n|no)  printf 'n'; return ;;
      *) echo "  Please answer y or n." >/dev/tty ;;
    esac
  done
}

detect_rust_target() {
  local host="$1" port="${2:-22}" ssh_opts="${3:-}"
  local arch
  if is_local "$host"; then
    arch="$(uname -m 2>/dev/null || echo "")"
  else
    # shellcheck disable=SC2086
    arch="$(ssh -p "$port" $ssh_opts -o ConnectTimeout=5 -o BatchMode=yes "$host" 'uname -m' 2>/dev/null || echo "")"
  fi
  case "$arch" in
    x86_64)  printf 'x86_64-unknown-linux-musl' ;;
    aarch64) printf 'aarch64-unknown-linux-musl' ;;
    armv7l)  printf 'armv7-unknown-linux-musleabihf' ;;
    *)       printf '' ;;
  esac
}

build_service_json() {
  local host="$1" port="$2" ssh_opts="$3" base_dir="$4" svc="$5" rust_target="$6" sudo_rsync="$7"
  local remote_dir="${base_dir}/${svc}"
  local svc_user="$svc"
  local svc_name="credo-${svc}"

  local json
  json=$(jq -cn \
    --arg host "$host" \
    --arg remote_dir "$remote_dir" \
    --argjson port "$port" \
    --arg rust_target "$rust_target" \
    --arg remote_user "$svc_user" \
    --arg remote_group "$svc_user" \
    --arg service_name "$svc_name" \
    --argjson sudo_rsync "$sudo_rsync" \
    '{host: $host, remoteDir: $remote_dir, sshPort: $port,
      rustTarget: $rust_target, rustProfile: "release",
      sudoRsync: $sudo_rsync, remoteUser: $remote_user,
      remoteGroup: $remote_group, serviceName: $service_name}')
  if [[ -n "$ssh_opts" ]]; then
    json=$(jq -c --arg v "$ssh_opts" '. + {sshOpts: $v}' <<< "$json")
  fi
  printf '%s' "$json"
}

build_dashboard_json() {
  local host="$1" port="$2" ssh_opts="$3" base_dir="$4" sudo_rsync="$5"
  local remote_dir="${base_dir}/dashboard"

  local json
  json=$(jq -cn \
    --arg host "$host" \
    --arg remote_dir "$remote_dir" \
    --argjson port "$port" \
    --arg remote_user "dashboard" \
    --arg remote_group "dashboard" \
    --arg service_name "credo-dashboard" \
    --argjson sudo_rsync "$sudo_rsync" \
    '{host: $host, remoteDir: $remote_dir, sshPort: $port,
      rustProfile: "release", sudoRsync: $sudo_rsync,
      remoteUser: $remote_user, remoteGroup: $remote_group,
      serviceName: $service_name}')
  if [[ -n "$ssh_opts" ]]; then
    json=$(jq -c --arg v "$ssh_opts" '. + {sshOpts: $v}' <<< "$json")
  fi
  printf '%s' "$json"
}

build_corgi_entry_json() {
  local name="$1" host="$2" port="$3" ssh_opts="$4" base_dir="$5" rust_target="$6" sudo_rsync="$7" use_sudo="${8:-true}"
  local remote_dir="${base_dir}/corgi"

  local json
  json=$(jq -cn \
    --arg name "$name" \
    --arg host "$host" \
    --arg remote_dir "$remote_dir" \
    --argjson port "$port" \
    --arg rust_target "$rust_target" \
    --arg remote_user "corgi" \
    --arg remote_group "corgi" \
    --arg service_name "credo-corgi" \
    --argjson sudo_rsync "$sudo_rsync" \
    --argjson use_sudo "$use_sudo" \
    '{name: $name, host: $host, remoteDir: $remote_dir, sshPort: $port,
      rustTarget: $rust_target, rustProfile: "release",
      sudoRsync: $sudo_rsync, useSudo: $use_sudo,
      remoteUser: $remote_user,
      remoteGroup: $remote_group, serviceName: $service_name}')
  if [[ -n "$ssh_opts" ]]; then
    json=$(jq -c --arg v "$ssh_opts" '. + {sshOpts: $v}' <<< "$json")
  fi
  printf '%s' "$json"
}

run_init() {
  local out_path="$CONFIG_PATH"

  echo ""
  echo "================================================================"
  echo "  credo install — interactive config generator"
  echo "  Writes: $out_path"
  echo "================================================================"
  echo ""
  echo "Press Enter to accept the default shown in [brackets]."
  echo ""

  # -- Host --
  local host
  host="$(ask_init "Remote host (user@hostname, or 'local')" "local")"
  echo ""

  # -- SSH port --
  local port_str
  port_str="$(ask_init "SSH port" "22")"
  local port
  if [[ "$port_str" =~ ^[0-9]+$ ]]; then port="$port_str"; else port=22; fi
  echo ""

  # -- SSH opts --
  local ssh_opts
  ssh_opts="$(ask_init "Extra SSH options (or leave blank)" "")"
  echo ""

  # -- Rust target --
  echo "  Detecting remote architecture..."
  local detected_target
  detected_target="$(detect_rust_target "$host" "$port" "$ssh_opts")"
  if [[ -n "$detected_target" ]]; then
    echo "  Detected: $detected_target"
  else
    echo "  Could not detect (SSH may not be available yet)."
    detected_target="x86_64-unknown-linux-musl"
  fi
  local rust_target
  rust_target="$(ask_init "Rust target triple" "$detected_target")"
  echo ""

  # -- Base install dir --
  local base_dir
  base_dir="$(ask_init "Base install directory on remote" "/var/apps/credo")"
  echo ""

  # -- CA cert source (on this management machine) --
  echo "  Local CA cert path — the credo-catrust.pem on THIS machine (generated by the PKI ceremony)."
  echo "  Deployed to each corgi host at dirname(remoteDir)/credo-catrust.pem."
  local local_ca_trust_path
  local_ca_trust_path="$(ask_init "Local CA cert path" "${base_dir}/credo-catrust.pem")"
  echo ""

  # -- Services --
  echo "Which services to include?"
  local want_shepherd want_vigil want_corgi want_dashboard
  # shellcheck disable=SC2034
  want_shepherd="$(ask_init_yn "  shepherd" "y")"
  # shellcheck disable=SC2034
  want_vigil="$(ask_init_yn "  vigil" "y")"
  want_corgi="$(ask_init_yn "  corgi" "y")"
  want_dashboard="$(ask_init_yn "  dashboard (TypeScript BFF)" "n")"
  echo ""

  # -- Sudo for rsync --
  local sudo_rsync_yn sudo_rsync
  sudo_rsync_yn="$(ask_init_yn "Use sudo for rsync + mkdir on remote (needed when target dirs are owned by service users)" "y")"
  if [[ "$sudo_rsync_yn" == "y" ]]; then sudo_rsync="true"; else sudo_rsync="false"; fi
  echo ""

  # -- Corgi instance --
  local corgi_names=()
  local corgi_use_sudos=()
  if [[ "$want_corgi" == "y" ]]; then
    local cname corgi_us_yn corgi_us
    cname="$(ask_init "Corgi instance name" "corgi-01")"
    corgi_us_yn="$(ask_init_yn "  Use sudo on corgi host" "y")"
    if [[ "$corgi_us_yn" == "y" ]]; then corgi_us="true"; else corgi_us="false"; fi
    corgi_names=("$cname")
    corgi_use_sudos=("$corgi_us")
    echo ""
  fi

  # -- Build JSON --
  local config_json="{}"
  local svc

  for svc in shepherd vigil; do
    local want_var="want_${svc}"
    if [[ "${!want_var}" == "y" ]]; then
      local svc_json
      svc_json="$(build_service_json "$host" "$port" "$ssh_opts" "$base_dir" "$svc" "$rust_target" "$sudo_rsync")"
      config_json="$(jq -c --arg k "$svc" --argjson v "$svc_json" '. + {($k): $v}' <<< "$config_json")"
    fi
  done

  if [[ "$want_dashboard" == "y" ]]; then
    local dash_json
    dash_json="$(build_dashboard_json "$host" "$port" "$ssh_opts" "$base_dir" "$sudo_rsync")"
    config_json="$(jq -c --argjson v "$dash_json" '. + {dashboard: $v}' <<< "$config_json")"
  fi

  if [[ "$want_corgi" == "y" && ${#corgi_names[@]} -gt 0 ]]; then
    local corgis_arr="[]"
    local i cname
    for i in "${!corgi_names[@]}"; do
      cname="${corgi_names[$i]}"
      local entry
      entry="$(build_corgi_entry_json "$cname" "$host" "$port" "$ssh_opts" "$base_dir" "$rust_target" "$sudo_rsync" "${corgi_use_sudos[$i]:-true}")"
      corgis_arr="$(jq -c --argjson e "$entry" '. + [$e]' <<< "$corgis_arr")"
    done
    config_json="$(jq -c --argjson corgis "$corgis_arr" '. + {corgis: $corgis}' <<< "$config_json")"
  fi

  # -- Inject top-level fields --
  config_json="$(jq -c --arg v "$local_ca_trust_path" '. + {localCaTrustPath: $v}' <<< "$config_json")"

  # -- Write --
  printf '%s\n' "$config_json" | jq '.' > "$out_path"
  echo "================================================================"
  echo "  Written: $out_path"
  echo ""
  echo "  Next steps (in order):"
  echo "    1. Review the file above and adjust if needed"
  echo "    2. ./scripts/install setup   — create users, groups, dirs, systemd units on all configured hosts
       (To add a new corgi later: ./scripts/install setup corgi:<name>)"
  echo "    3. ./scripts/install         — build and deploy binaries"
  echo "    4. ./scripts/bootstrap       — ceremony + service config + bootstrap sequence"
  echo ""
  echo "  To re-run this wizard:  ./scripts/install init"
  echo "================================================================"
  echo ""
}

# ---------------------------------------------------------------------------
# Setup subcommand — create service users/groups and systemd unit files
# Runs on the REMOTE host via SSH (or locally when host == "local").
# ---------------------------------------------------------------------------

SETUP_DRY_RUN=false
SETUP_SUDO="sudo"  # Set to "" when useSudo: false (e.g. root login, no sudo available)

setup_run() {
  local cmd="$1" host="$2" port="${3:-22}" ssh_opts="${4:-}"
  if $SETUP_DRY_RUN; then
    printf '[setup] DRY RUN: %s\n' "$cmd"
    return 0
  fi
  if is_local "$host"; then
    eval "$cmd"
  else
    # shellcheck disable=SC2086
    ssh -p "$port" $ssh_opts "$host" "$cmd"
  fi
}

setup_users_groups() {
  local host="$1" port="$2" ssh_opts="$3" services=("${@:4}")

  echo "[setup] Creating system users and groups..."

  # credo-cert group for cert consumers
  setup_run "getent group credo-cert >/dev/null 2>&1 || $SETUP_SUDO groupadd --system credo-cert" \
    "$host" "$port" "$ssh_opts"
  echo "[setup]   group: credo-cert"

  local svc
  for svc in "${services[@]}"; do
    # Always ensure the primary group exists first — create user only if absent.
    # Doing these separately handles the case where a prior partial setup created
    # the user but not its primary group (e.g. useradd was run without --user-group).
    setup_run "getent group '$svc' >/dev/null 2>&1 || $SETUP_SUDO groupadd --system '$svc'" \
      "$host" "$port" "$ssh_opts"
    setup_run "id '$svc' >/dev/null 2>&1 || $SETUP_SUDO useradd --system --no-create-home --shell /usr/sbin/nologin -g '$svc' '$svc'" \
      "$host" "$port" "$ssh_opts"
    echo "[setup]   user/group: $svc"
  done

  # shepherd, vigil, and dashboard need credo-cert supplementary group to read the cert store
  for svc in shepherd vigil dashboard; do
    local found=false
    local s
    for s in "${services[@]}"; do [[ "$s" == "$svc" ]] && found=true && break; done
    if $found; then
      setup_run "$SETUP_SUDO usermod -aG credo-cert '$svc'" "$host" "$port" "$ssh_opts"
      echo "[setup]   $svc added to credo-cert"
    fi
  done
}

setup_cert_store() {
  # corgi_dir is the corgi remoteDir (e.g. /var/apps/credo/corgi).
  # The cert store lives at corgi_dir/store/ with setgid so all new files
  # inherit the credo-cert group automatically.
  local host="$1" port="$2" ssh_opts="$3" corgi_dir="$4"
  local store="${corgi_dir}/store"
  echo "[setup] Creating corgi cert store: $store"
  setup_run "$SETUP_SUDO mkdir -p '${store}/archive' '${store}/live' '${store}/pending' && $SETUP_SUDO chown corgi:credo-cert '${store}' '${store}/archive' '${store}/live' '${store}/pending' && $SETUP_SUDO chmod 2750 '${store}' '${store}/live' && $SETUP_SUDO chmod 2755 '${store}/archive' '${store}/pending'" \
    "$host" "$port" "$ssh_opts"
  echo "[setup]   store/:         corgi:credo-cert 2750 (setgid, group-only traverse)"
  echo "[setup]   store/archive/: corgi:credo-cert 2755 (setgid, world-traversable)"
  echo "[setup]   store/live/:    corgi:credo-cert 2750 (setgid, group-only traverse)"
  echo "[setup]   store/pending/: corgi:credo-cert 2755 (setgid, world-traversable)"
}

setup_service_dir() {
  local host="$1" port="$2" ssh_opts="$3" svc="$4" dir="$5"
  setup_run "$SETUP_SUDO mkdir -p '$dir' && $SETUP_SUDO chown '${svc}:${svc}' '$dir'" \
    "$host" "$port" "$ssh_opts"
  echo "[setup]   $dir (${svc}:${svc})"
}

setup_ca_cert() {
  # Deploy the CA cert to the corgi host and set ownership corgi:corgi 644 so
  # bs_ca can overwrite it during bootstrap. The design (matching scripts/bootstrap
  # Phase 2) requires the file to be corgi-writable at caTrustPath before bootstrap runs.
  local host="$1" port="$2" ssh_opts="$3" local_ca_cert="$4" remote_ca_path="$5"

  if [[ -z "$local_ca_cert" ]]; then
    echo "[setup] WARNING: localCaTrustPath not set in .install.json — skipping CA cert deploy" >&2
    echo "[setup]          Add 'localCaTrustPath' to .install.json or run: scripts/install init" >&2
    return 0
  fi
  if [[ ! -f "$local_ca_cert" ]]; then
    echo "[setup] WARNING: CA cert not found at $local_ca_cert — skipping" >&2
    echo "[setup]          Run the PKI ceremony first, or update localCaTrustPath in .install.json" >&2
    return 0
  fi

  echo "[setup] Deploying CA cert: $remote_ca_path (corgi:corgi 644)"

  if $SETUP_DRY_RUN; then
    echo "[setup] DRY RUN: deploy $local_ca_cert -> ${host}:${remote_ca_path}"
    echo "[setup] DRY RUN: $SETUP_SUDO chown corgi:corgi '$remote_ca_path' && $SETUP_SUDO chmod 644 '$remote_ca_path'"
    return 0
  fi

  local remote_ca_dir
  remote_ca_dir="$(dirname "$remote_ca_path")"

  if is_local "$host"; then
    # shellcheck disable=SC2086
    $SETUP_SUDO mkdir -p "$remote_ca_dir"
    # shellcheck disable=SC2086
    $SETUP_SUDO cp "$local_ca_cert" "$remote_ca_path"
    # shellcheck disable=SC2086
    $SETUP_SUDO chown corgi:corgi "$remote_ca_path"
    # shellcheck disable=SC2086
    $SETUP_SUDO chmod 644 "$remote_ca_path"
  else
    # shellcheck disable=SC2086
    cat "$local_ca_cert" | ssh -p "$port" $ssh_opts "$host" \
      "$SETUP_SUDO mkdir -p '$remote_ca_dir' && $SETUP_SUDO tee '$remote_ca_path' > /dev/null && $SETUP_SUDO chown corgi:corgi '$remote_ca_path' && $SETUP_SUDO chmod 644 '$remote_ca_path'"
  fi
  echo "[setup]   $remote_ca_path (corgi:corgi 644)"
}

write_systemd_unit() {
  local host="$1" port="$2" ssh_opts="$3" svc="$4" exec_path="$5" working_dir="$6"
  local unit_name="credo-${svc}"
  local unit_path="/etc/systemd/system/${unit_name}.service"

  local supp_groups=""
  if [[ "$svc" == "shepherd" || "$svc" == "vigil" || "$svc" == "dashboard" ]]; then
    supp_groups="SupplementaryGroups=credo-cert"
  fi

  local supp_line=""
  [[ -n "$supp_groups" ]] && supp_line=$'\n'"${supp_groups}"

  local unit
  unit="$(cat <<EOF
[Unit]
Description=Credo ${svc^}
After=network.target
Wants=network.target

[Service]
Type=simple
User=${svc}
Group=${svc}${supp_line}
WorkingDirectory=${working_dir}
ExecStart=${exec_path} server start
ExecStop=${exec_path} server stop
ExecReload=/bin/kill -HUP \$MAINPID
Restart=on-failure
RestartSec=5

NoNewPrivileges=yes
ProtectSystem=strict
PrivateTmp=yes
ProtectHome=yes
ReadWritePaths=${working_dir}

[Install]
WantedBy=multi-user.target
Alias=${svc}.service
EOF
)"

  if $SETUP_DRY_RUN; then
    printf '[setup] DRY RUN: write %s\n' "$unit_path"
    printf '%s\n' "$unit" | sed 's/^/  /'
    return 0
  fi

  if is_local "$host"; then
    # shellcheck disable=SC2086
    printf '%s\n' "$unit" | $SETUP_SUDO tee "$unit_path" >/dev/null
  else
    # shellcheck disable=SC2086
    printf '%s\n' "$unit" | ssh -p "$port" $ssh_opts "$host" "$SETUP_SUDO tee '$unit_path' >/dev/null"
  fi
  echo "[setup]   wrote $unit_path"
}

run_setup_one_corgi() {
  # Full setup for one corgi node: users/groups, corgi dir, cert store, systemd unit.
  # Called by run_setup for each corgi entry and by run_setup_corgi_by_name for targeted setup.
  local name="$1" host="$2" port="$3" ssh_opts="$4" remote_dir="$5"

  # Set SETUP_SUDO based on the useSudo field for this corgi entry.
  local use_sudo
  use_sudo=$(jq -r --arg n "$name" '.corgis[] | select(.name == $n) | if .useSudo == false then "false" else "true" end' "$CONFIG_PATH")
  if [[ "$use_sudo" == "false" ]]; then
    SETUP_SUDO=""
  else
    SETUP_SUDO="sudo"
  fi

  echo ""
  echo "================================================================"
  printf "  credo install setup — corgi: %s\n" "$name"
  printf "  Host    : %s\n" "$host"
  printf "  Dir     : %s\n" "$remote_dir"
  [[ "$use_sudo" == "false" ]] && echo "  Sudo    : disabled"
  $SETUP_DRY_RUN && echo "  Mode    : DRY RUN"
  echo "================================================================"
  echo ""

  setup_users_groups "$host" "$port" "$ssh_opts" "corgi"
  echo ""

  echo "[setup] Creating corgi directory..."
  setup_service_dir "$host" "$port" "$ssh_opts" "corgi" "$remote_dir"
  echo ""

  setup_cert_store "$host" "$port" "$ssh_opts" "$remote_dir"
  echo ""

  local local_ca_cert remote_ca_path
  local_ca_cert=$(jq -r '.localCaTrustPath // empty' "$CONFIG_PATH")
  # Remote CA cert always lives at dirname(corgi_remoteDir)/credo-catrust.pem
  # matching the caTrustPath in vars.json on each host.
  remote_ca_path="$(dirname "$remote_dir")/credo-catrust.pem"
  setup_ca_cert "$host" "$port" "$ssh_opts" "$local_ca_cert" "$remote_ca_path"
  echo ""

  echo "[setup] Writing systemd unit file..."
  write_systemd_unit "$host" "$port" "$ssh_opts" "corgi" "${remote_dir}/corgi" "$remote_dir"

  echo "[setup] Running systemctl daemon-reload..."
  setup_run "$SETUP_SUDO systemctl daemon-reload" "$host" "$port" "$ssh_opts"

  echo ""
  echo "================================================================"
  echo "  Corgi $name setup complete."
  echo "  Next: scripts/install corgi:$name   — deploy the binary"
  echo "  Then on $host: ${SETUP_SUDO:+$SETUP_SUDO }systemctl enable --now credo-corgi"
  echo "================================================================"
}

run_setup_corgi_by_name() {
  # Setup a specific corgi node by name — for adding new corgis to existing deployments.
  local name="$1"
  local config_path="$CONFIG_PATH"

  if [[ ! -f "$config_path" ]]; then
    echo "[setup] Config not found: $config_path" >&2
    echo "[setup] Run: scripts/install init" >&2
    exit 1
  fi

  local exists
  exists=$(jq -r --arg n "$name" '.corgis[]? | select(.name == $n) | .name' "$config_path")
  if [[ -z "$exists" ]]; then
    local available
    available=$(jq -r '.corgis[]?.name' "$config_path" | tr '\n' ' ')
    echo "[setup] Corgi '$name' not found in $config_path" >&2
    echo "[setup] Configured corgis: ${available:-(none)}" >&2
    exit 1
  fi

  local host port ssh_opts remote_dir
  host=$(jq -r --arg n "$name" '.corgis[] | select(.name == $n) | .host // empty' "$config_path")
  port=$(jq -r --arg n "$name" '.corgis[] | select(.name == $n) | .sshPort // 22' "$config_path")
  ssh_opts=$(jq -r --arg n "$name" '.corgis[] | select(.name == $n) | .sshOpts // ""' "$config_path")
  remote_dir=$(jq -r --arg n "$name" '.corgis[] | select(.name == $n) | .remoteDir // empty' "$config_path")

  if [[ -z "$host" || -z "$remote_dir" ]]; then
    echo "[setup] Corgi '$name' is missing host or remoteDir in $config_path" >&2
    exit 1
  fi

  run_setup_one_corgi "$name" "$host" "$port" "$ssh_opts" "$remote_dir"
}

run_setup() {
  local config_path="$CONFIG_PATH"

  if [[ ! -f "$config_path" ]]; then
    echo "[setup] Config not found: $config_path" >&2
    echo "[setup] Run: scripts/install init   — to generate it" >&2
    exit 1
  fi

  # Collect main services (shepherd, vigil, dashboard) and their shared host
  local main_services=()
  local main_host="" main_port="22" main_ssh_opts=""

  for svc in shepherd vigil dashboard; do
    if jq -e ".$svc" "$config_path" >/dev/null 2>&1; then
      main_services+=("$svc")
      if [[ -z "$main_host" ]]; then
        main_host=$(jq -r --arg k "$svc" '.[$k].host // empty' "$config_path")
        main_port=$(jq -r --arg k "$svc" '.[$k].sshPort // 22' "$config_path")
        main_ssh_opts=$(jq -r --arg k "$svc" '.[$k].sshOpts // ""' "$config_path")
      fi
    fi
  done

  # Setup main services on their host (if any)
  if [[ ${#main_services[@]} -gt 0 && -n "$main_host" ]]; then
    local first_remote_dir base_dir
    first_remote_dir=$(jq -r --arg k "${main_services[0]}" '.[$k].remoteDir // empty' "$config_path")
    base_dir="${first_remote_dir%/*}"
    [[ -z "$base_dir" ]] && base_dir="/var/apps/credo"
    local main_use_sudo
    main_use_sudo=$(jq -r --arg k "${main_services[0]}" 'if .[$k].useSudo == false then "false" else "true" end' "$config_path")
    if [[ "$main_use_sudo" == "false" ]]; then SETUP_SUDO=""; else SETUP_SUDO="sudo"; fi

    echo ""
    echo "================================================================"
    echo "  credo install setup"
    echo "  Host     : $main_host"
    echo "  Base dir : $base_dir"
    echo "  Services : ${main_services[*]}"
    $SETUP_DRY_RUN && echo "  Mode     : DRY RUN"
    echo "================================================================"
    echo ""

    setup_users_groups "$main_host" "$main_port" "$main_ssh_opts" "${main_services[@]}"
    echo ""

    echo "[setup] Creating service directories..."
    local svc
    for svc in "${main_services[@]}"; do
      local svc_dir
      svc_dir=$(jq -r --arg k "$svc" '.[$k].remoteDir // empty' "$config_path")
      [[ -z "$svc_dir" ]] && continue
      setup_service_dir "$main_host" "$main_port" "$main_ssh_opts" "$svc" "$svc_dir"
    done
    echo ""

    echo "[setup] Writing systemd unit files..."
    for svc in "${main_services[@]}"; do
      local remote_dir
      remote_dir=$(jq -r --arg k "$svc" '.[$k].remoteDir // empty' "$config_path")
      [[ -z "$remote_dir" ]] && continue
      write_systemd_unit "$main_host" "$main_port" "$main_ssh_opts" "$svc" \
        "${remote_dir}/${svc}" "$remote_dir"
    done

    setup_run "$SETUP_SUDO systemctl daemon-reload" "$main_host" "$main_port" "$main_ssh_opts"

    echo ""
    echo "================================================================"
    echo "  Main service setup complete."
    echo "  Units are NOT yet enabled or started."
    echo "  After deploying binaries, run:"
    for svc in "${main_services[@]}"; do
      echo "    ${SETUP_SUDO:+$SETUP_SUDO }systemctl enable --now credo-${svc}"
    done
    echo "================================================================"
  fi

  # Setup each corgi on its own host (idempotent when on same host as main services)
  if jq -e '.corgis | length > 0' "$config_path" >/dev/null 2>&1; then
    local corgi_json name c_host c_port c_ssh_opts c_remote_dir
    while IFS= read -r corgi_json; do
      name=$(jq -r '.name // empty' <<< "$corgi_json")
      c_host=$(jq -r '.host // empty' <<< "$corgi_json")
      c_port=$(jq -r '.sshPort // 22' <<< "$corgi_json")
      c_ssh_opts=$(jq -r '.sshOpts // ""' <<< "$corgi_json")
      c_remote_dir=$(jq -r '.remoteDir // empty' <<< "$corgi_json")
      [[ -z "$name" || -z "$c_host" ]] && continue
      run_setup_one_corgi "$name" "$c_host" "$c_port" "$c_ssh_opts" "$c_remote_dir"
    done < <(jq -c '.corgis[]' "$config_path")
  fi

  if [[ ${#main_services[@]} -eq 0 ]] && ! jq -e '.corgis | length > 0' "$config_path" >/dev/null 2>&1; then
    echo "[setup] No services configured in $config_path" >&2
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

print_usage() {
  cat <<'EOF'
Usage:
  ./scripts/install init                Generate .install.json interactively
  ./scripts/install setup               Create service users/groups, dirs, and systemd units (all hosts)
  ./scripts/install setup corgi:<name>  Setup a single corgi node — useful when adding a new corgi
  ./scripts/install [options] [target ...]

Targets (default: all):
  all            Deploy shepherd, vigil, dashboard, enroll, wizard, and all corgis
  shepherd       Deploy shepherd
  vigil          Deploy vigil (TypeScript or Rust binary per vigil.rustTarget in .install.json)
  dashboard      Deploy dashboard
  enroll         Deploy enroll
  wizard         Deploy wizard
  corgi          Deploy all corgis
  corgi:<name>   Deploy a specific corgi, e.g. corgi:corgi-01
  scripts        Deploy scripts/ (bootstrap, ceremony, lib) to $base_dir/scripts/ on the remote

  Multiple targets may be combined:
    ./scripts/install vigil shepherd corgi:corgi-01

Options:
  --dry-run        Build + preview rsync without transferring files
  --print-build-cmd Print the exact Rust build command before executing it
  --parallel       Deploy all selected targets in parallel
  --config <path>  Path to deploy config (default: .install.json)
  --help           Show this help

Config:
  Copy examples/.install.json.example to .install.json and fill in your hosts.

  Per-service fields:
    host           "user@hostname" or "local"/"localhost"/"127.0.0.1" for local deploy  (required)
    remoteDir      "/opt/credo/shepherd"  (required)
    files          list of paths to deploy, relative to service root
    sshPort        SSH port, default 22
    sshOpts        extra SSH flags string, e.g. "-o StrictHostKeyChecking=no"
    owner          "user:group" — sudo chown -R after sync (auto-set from remoteUser:remoteGroup if omitted)
    dirMode        octal mode string — sudo chmod applied to remoteDir after chown, e.g. "750"
    rsyncOpts      extra rsync flags, e.g. "-O" for OpenWRT targets
    serviceName    systemd unit name, e.g. "credo-shepherd" — auto-runs "sudo systemctl restart <name>" after deploy
    restartMode    "restart" (default), "reload" (SIGHUP), or "none" — controls the systemctl verb used with serviceName
    postDeploy     remote shell command after install — overrides serviceName/restartMode when set
    rustTarget     e.g. "aarch64-unknown-linux-musl" — enables Rust binary build
    rustProfile    "debug" or "release" (default: "release")
    buildOverrides optional build-only overrides: {"env": {"RUSTFLAGS": "-C target-cpu=goldmont"}, "args": ["--locked"]}
    sudoRsync      true — use sudo on the remote for mkdir and rsync (needed when target dir is owned by a different user)
    remoteUser     service user on remote, e.g. "shepherd" — used with sudoRsync for "sudo -u <user> rsync"
    remoteGroup    service group on remote, e.g. "shepherd" — combined with remoteUser to auto-set owner
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)   DRY_RUN=true ;;
      --print-build-cmd) PRINT_BUILD_CMD=true ;;
      --parallel)  PARALLEL=true ;;
      --config)
        [[ -z "${2:-}" ]] && { echo "[install] --config requires a path argument" >&2; exit 1; }
        CONFIG_PATH=$(realpath "$2"); shift ;;
      --config=*)  CONFIG_PATH=$(realpath "${1#--config=}") ;;
      -h|--help)   print_usage; exit 0 ;;
      corgi:*)     TARGETS+=("$1") ;;
      all|shepherd|vigil|dashboard|enroll|wizard|corgi|scripts) TARGETS+=("$1") ;;
      *)
        echo "[install] Unknown target: '$1'. Use --help for usage." >&2
        exit 1 ;;
    esac
    shift
  done
  if [[ ${#TARGETS[@]} -eq 0 ]]; then TARGETS=("all"); fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  if [[ "${1:-}" == "init" ]]; then
    run_init
    exit 0
  fi

  if [[ "${1:-}" == "setup" ]]; then
    shift
    local setup_target=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --dry-run) SETUP_DRY_RUN=true ;;
        --config)
          [[ -z "${2:-}" ]] && { echo "[setup] --config requires a path" >&2; exit 1; }
          CONFIG_PATH=$(realpath "$2"); shift ;;
        --config=*) CONFIG_PATH=$(realpath "${1#--config=}") ;;
        corgi:*)   setup_target="${1#corgi:}" ;;
        *) echo "[setup] Unknown option: $1" >&2; exit 1 ;;
      esac
      shift
    done
    if [[ -n "$setup_target" ]]; then
      run_setup_corgi_by_name "$setup_target"
    else
      run_setup
    fi
    exit 0
  fi

  parse_args "$@"

  if [[ ! -f "$CONFIG_PATH" ]] && [[ -f "$REPO_DIR/.deploy.json" ]]; then
    echo "[install] Warning: .install.json not found but .deploy.json exists — using it. Rename it to .install.json." >&2
    CONFIG_PATH="$REPO_DIR/.deploy.json"
  fi

  if [[ ! -f "$CONFIG_PATH" ]]; then
    echo "[install] Config not found: $CONFIG_PATH" >&2
    echo "[install] Run: scripts/install init   — to generate .install.json interactively" >&2
    echo "[install] Or copy examples/.install.json.example to .install.json and fill in manually." >&2
    exit 1
  fi

  expand_targets

  if [[ ${#JOB_LABELS[@]} -eq 0 ]]; then
    echo "[install] No targets to deploy." >&2
    exit 0
  fi

  execute_jobs
}

main "$@"
