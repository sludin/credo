# CA ceremony configuration — loaded by generate-openssl-cnf.sh and ceremony scripts.
#
# Run order:
#   1. ./scripts/generate-openssl-cnf.sh --env-file ca-vars.env --force
#   2. ./scripts/bootstrap-roots.sh [--passphrase]
#   3. ./scripts/issue-intermediary.sh
#   4. Move ca/root-ecdsa/private/ to offline storage (USB, air-gapped machine, or HSM).

CA_DIR=./ca
ORG="Vigil Cert Authority"
COUNTRY=US

# Common names for the root and active intermediate certificate.
ROOT_ECDSA_CN="Vigil Root X1"
INT_ECDSA_CN="E1"

# Validity in days.
# Scripts warn if ROOT_DAYS < 365 or INT_DAYS < 30.
# Production recommendations: ROOT_DAYS=3650 (10yr), INT_DAYS=730 (2yr)
ROOT_DAYS=3650
INT_DAYS=730

# CRL validity — how long until a new CRL must be published.
ROOT_CRL_DAYS=90
INT_CRL_DAYS=7

# Embedded in cert extensions for future CRL/OCSP use.
# This URL does not need to be served for the CA to function internally.
PKI_BASE_URL=http://pki.example.com
